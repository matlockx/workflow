{
  "name": "opencode",
  "version": "0.1.0",
  "description": "OpenCode workflow framework configuration and utilities",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:bash": "bats test/bin/",
    "test:all": "npm run test && npm run test:bash",
    "lint": "echo 'No linter configured yet'",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "lefthook": "^1.6.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "lib/**/*.js"
    ]
  }
}
