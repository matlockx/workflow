{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "permission": {
    "doom_loop": "deny",
    "*": "ask"
  },
  "mcp": {
    "firefox-devtools": {
      "type": "local",
      "command": [
        "npx",
        "firefox-devtools-mcp@latest"
      ]
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  }
}
