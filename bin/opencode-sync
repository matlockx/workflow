#!/usr/bin/env bash
#
# opencode-sync - Sync workflow files from the opencode repo into an initialized project
#
# Usage:
#   opencode-sync [--force] [target-dir]
#
# Examples:
#   opencode-sync                  # Sync into current directory
#   opencode-sync ~/projects/myapp # Sync into specified directory
#   opencode-sync --force          # Nuke .agent/ and regenerate AGENTS.md + opencode.json
#
# What it does:
#   - Updates .agent/commands/* (slash commands)
#   - Updates .agent/agents/*, .agent/lib/*, .agent/backends/,
#     and .agent/skills/ from the opencode source repo
#   - Ensures .opencode -> .agent symlink exists
#   - Preserves .agent/config.json, .agent/state/, AGENTS.md, opencode.json
#   - Re-runs language-agent detection based on config.json language setting
#   - Does NOT overwrite AGENTS.md (project-specific, user-editable)
#   - Does NOT touch .agent/state/ (runtime workflow data)
#   - Does NOT change your backend config
#
# With --force:
#   - Backs up .agent/ to .agent-backup/
#   - Nukes .agent/ entirely and rebuilds from source
#   - Restores .agent/config.json and .agent/state/ from backup
#   - Regenerates AGENTS.md from template and opencode.json from canonical content
#
# AIDEV-NOTE: This script is the "update" companion to opencode-init.
# It refreshes workflow machinery while preserving all project-specific config.
# Uses plural directory names (commands/, agents/) and single .opencode -> .agent symlink.

set -euo pipefail

# ============================================
# Configuration
# ============================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OPENCODE_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
TARGET_DIR="."
DRY_RUN=""
VERBOSE=""
FORCE=""

# Colors (if terminal supports them)
if [[ -t 1 ]]; then
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[0;33m'
  BLUE='\033[0;34m'
  NC='\033[0m'
else
  RED=''; GREEN=''; YELLOW=''; BLUE=''; NC=''
fi

# ============================================
# Helper Functions
# ============================================

log_info()    { echo -e "${BLUE}ℹ${NC} $1"; }
log_success() { echo -e "${GREEN}✓${NC} $1"; }
log_warn()    { echo -e "${YELLOW}⚠${NC} $1"; }
log_error()   { echo -e "${RED}✗${NC} $1" >&2; }
log_verbose() { [[ -n "$VERBOSE" ]] && echo -e "  ${NC}$1" || true; }

usage() {
  cat <<EOF
Usage: opencode-sync [OPTIONS] [target-dir]

Sync workflow files from the opencode repo into an already-initialized project.

Options:
  --dry-run     Show what would be updated without making changes
  --force       Nuke .agent/ and regenerate AGENTS.md + opencode.json from templates
                (backs up .agent/ to .agent-backup/ first)
  --verbose     Show each file being copied
  --help, -h    Show this help message

Arguments:
  target-dir    Directory to sync into (default: current directory)

What is updated:
  .agent/commands/     All slash commands (synced, stale removed)
  .opencode            Symlink to .agent (ensured)
  .agent/agents/       All agents from source repo (synced, stale removed)
  .agent/lib/          backend-loader, plan-state (replaced)
  .agent/backends/     Active backend index.js + README (replaced)
  .agent/skills/       All skills from source repo (synced, stale removed)

What is preserved:
  .agent/config.json   Your backend configuration
  .agent/state/        Runtime workflow state (issues, tasks)
  AGENTS.md            Your project context (user-editable)
  opencode.json        Your OpenCode provider/model config
  plans/               Your plan documents

With --force:
  .agent/              Deleted entirely, then rebuilt from source (backed up first)
  AGENTS.md            Regenerated from template
  opencode.json        Regenerated from canonical content
  .agent-backup/       Previous .agent/ contents (for recovery)

EOF
  exit 0
}

# Copy a file if source exists; log result
sync_file() {
  local src="$1"
  local dst="$2"
  if [[ -f "$src" ]]; then
    if [[ -n "$DRY_RUN" ]]; then
      log_verbose "would copy: $dst"
    else
      mkdir -p "$(dirname "$dst")"
      cp "$src" "$dst"
      log_verbose "copied: $dst"
    fi
  else
    log_warn "Source not found, skipping: $src"
  fi
}

# Copy a directory's contents (non-recursive, one level)
sync_dir_files() {
  local src_dir="$1"
  local dst_dir="$2"
  if [[ ! -d "$src_dir" ]]; then
    log_warn "Source directory not found: $src_dir"
    return 0
  fi
  if [[ -z "$DRY_RUN" ]]; then
    mkdir -p "$dst_dir"
  fi
  for f in "$src_dir"/*; do
    [[ -f "$f" ]] || continue
    local fname; fname="$(basename "$f")"
    sync_file "$f" "$dst_dir/$fname"
  done
}

# ============================================
# Argument Parsing
# ============================================

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)     DRY_RUN="true"; shift ;;
    --force)       FORCE="true"; shift ;;
    --verbose|-v)  VERBOSE="true"; shift ;;
    --help|-h)     usage ;;
    -*)
      log_error "Unknown option: $1"
      echo "Run 'opencode-sync --help' for usage."
      exit 1
      ;;
    *)
      TARGET_DIR="$1"
      shift
      ;;
  esac
done

# ============================================
# Pre-flight Checks
# ============================================

if [[ ! -d "$TARGET_DIR" ]]; then
  log_error "Target directory does not exist: $TARGET_DIR"
  exit 1
fi

TARGET_DIR="$(cd "$TARGET_DIR" && pwd)"

if [[ ! -f "$TARGET_DIR/.agent/config.json" ]]; then
  log_error "No .agent/config.json found in: $TARGET_DIR"
  log_info  "Run 'opencode-init' first to initialize the project."
  exit 1
fi

# ============================================
# Read config to determine backend and language
# ============================================

# AIDEV-NOTE: We use basic grep/sed to extract values from config.json
# to avoid requiring jq or node on the host. The config schema is simple
# enough that this is reliable.
BACKEND=$(grep '"type"' "$TARGET_DIR/.agent/config.json" | head -1 | sed 's/.*"type"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')

if [[ -z "$BACKEND" ]]; then
  log_error "Could not determine backend from .agent/config.json"
  log_info  "Check that .agent/config.json has a valid \"type\" field."
  exit 1
fi

log_info "Target:  $TARGET_DIR"
log_info "Backend: $BACKEND"
[[ -n "$DRY_RUN" ]] && log_warn "Dry-run mode: no files will be written"
echo

# Validate backend directory exists
if [[ ! -d "$OPENCODE_ROOT/backends/$BACKEND" ]]; then
  log_error "Backend '$BACKEND' not found in opencode repo: $OPENCODE_ROOT/backends/"
  log_info  "Available backends: $(ls "$OPENCODE_ROOT/backends/" | grep -v '^interface' | grep -v '\.ts$' | grep -v '\.js$' | tr '\n' ' ')"
  exit 1
fi

# ============================================
# Language helpers (for AGENTS.md regeneration)
# ============================================

# AIDEV-NOTE: These mirror the lang_*_cmd functions in opencode-init.
# Duplicated here to keep opencode-sync self-contained (no sourcing opencode-init).
lang_build_cmd() {
  case "$1" in
    go)      echo "go build ./..." ;;
    rust)    echo "cargo build" ;;
    node)    echo "npm run build" ;;
    python)  echo "python -m build" ;;
    *)       echo "<fill in your build command>" ;;
  esac
}
lang_test_cmd() {
  case "$1" in
    go)      echo "go test ./..." ;;
    rust)    echo "cargo test" ;;
    node)    echo "npm test" ;;
    python)  echo "pytest" ;;
    *)       echo "<fill in your test command>" ;;
  esac
}
lang_lint_cmd() {
  case "$1" in
    go)      echo "golangci-lint run ./..." ;;
    rust)    echo "cargo clippy -- -D warnings" ;;
    node)    echo "npm run lint" ;;
    python)  echo "ruff check ." ;;
    *)       echo "<fill in your lint command>" ;;
  esac
}
lang_single_test_cmd() {
  case "$1" in
    go)      echo "go test ./path/to/package/..." ;;
    rust)    echo "cargo test test_name" ;;
    node)    echo "npm test -- --testPathPattern=<pattern>" ;;
    python)  echo "pytest path/to/test_file.py" ;;
    *)       echo "<fill in your single-test command>" ;;
  esac
}

generate_agents_md() {
  local project_name="$1"
  local lang_key="$2"
  local template_src="$OPENCODE_ROOT/templates/AGENTS.md.tmpl"
  local agents_md_dst="$TARGET_DIR/AGENTS.md"

  if [[ ! -f "$template_src" ]]; then
    log_warn "AGENTS.md template not found: $template_src — skipping generation"
    return 0
  fi

  local build_cmd; build_cmd="$(lang_build_cmd "$lang_key")"
  local test_cmd;  test_cmd="$(lang_test_cmd  "$lang_key")"
  local lint_cmd;  lint_cmd="$(lang_lint_cmd  "$lang_key")"
  local single_test_cmd; single_test_cmd="$(lang_single_test_cmd "$lang_key")"

  sed \
    -e "s|{{PROJECT_NAME}}|$project_name|g" \
    -e "s|{{BUILD_CMD}}|$build_cmd|g" \
    -e "s|{{TEST_CMD}}|$test_cmd|g" \
    -e "s|{{LINT_CMD}}|$lint_cmd|g" \
    -e "s|{{SINGLE_TEST_CMD}}|$single_test_cmd|g" \
    "$template_src" > "$agents_md_dst"

  log_success "Regenerated AGENTS.md (lang: $lang_key)"
}

# ============================================
# Force mode: backup, nuke, and regenerate
# ============================================

# AIDEV-NOTE: --force backs up .agent/ to .agent-backup/, nukes .agent/,
# restores config.json and state/ (needed for the sync to work), then
# regenerates AGENTS.md and opencode.json from templates. This is useful
# during active development of opencode itself when these files change often.

if [[ -n "$FORCE" ]]; then
  log_warn "Force mode: backing up .agent/ and regenerating AGENTS.md + opencode.json"
  echo

  if [[ -n "$DRY_RUN" ]]; then
    log_verbose "would back up .agent/ to .agent-backup/"
    log_verbose "would nuke .agent/"
    log_verbose "would restore .agent/config.json and .agent/state/ from backup"
    log_verbose "would regenerate AGENTS.md from template"
    log_verbose "would regenerate opencode.json"
  else
    # Back up .agent/ to .agent-backup/ (remove previous backup if any)
    if [[ -d "$TARGET_DIR/.agent-backup" ]]; then
      rm -rf "$TARGET_DIR/.agent-backup"
    fi
    cp -a "$TARGET_DIR/.agent" "$TARGET_DIR/.agent-backup"
    log_success "Backed up .agent/ to .agent-backup/"

    # Nuke .agent/
    rm -rf "$TARGET_DIR/.agent"
    log_success "Removed .agent/"

    # Restore config.json and state/ from backup
    mkdir -p "$TARGET_DIR/.agent"
    if [[ -f "$TARGET_DIR/.agent-backup/config.json" ]]; then
      cp "$TARGET_DIR/.agent-backup/config.json" "$TARGET_DIR/.agent/config.json"
      log_verbose "restored .agent/config.json from backup"
    fi
    if [[ -d "$TARGET_DIR/.agent-backup/state" ]]; then
      cp -a "$TARGET_DIR/.agent-backup/state" "$TARGET_DIR/.agent/state"
      log_verbose "restored .agent/state/ from backup"
    fi

    # Regenerate AGENTS.md from template
    PROJECT_NAME="$(basename "$TARGET_DIR")"
    # Read language from config.json if present
    LANG_KEY="default"
    if [[ -f "$TARGET_DIR/.agent/config.json" ]]; then
      detected_lang=$(grep '"language"' "$TARGET_DIR/.agent/config.json" 2>/dev/null | sed 's/.*"language"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' || true)
      if [[ -n "$detected_lang" ]]; then
        case "$detected_lang" in
          go|both) LANG_KEY="go" ;;
          rust)    LANG_KEY="rust" ;;
          node)    LANG_KEY="node" ;;
          python)  LANG_KEY="python" ;;
          *)       LANG_KEY="default" ;;
        esac
        log_verbose "detected language from config.json: $detected_lang (template key: $LANG_KEY)"
      fi
    fi
    generate_agents_md "$PROJECT_NAME" "$LANG_KEY"

    # Regenerate opencode.json
    cat > "$TARGET_DIR/opencode.json" <<'OCEOF'
{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".agent/agents/workflow-first.md"
  ]
}
OCEOF
    log_success "Regenerated opencode.json"
  fi

  echo
fi

# ============================================
# Sync Commands
# ============================================

# AIDEV-NOTE: Commands are stored in .agent/commands/ (plural). A single
# .opencode -> .agent symlink makes them discoverable by OpenCode.

log_info "Syncing commands to .agent/commands/..."
UPDATED_COMMANDS=0

# Migrate from old singular to new plural if needed
if [[ -d "$TARGET_DIR/.agent/command" && ! -d "$TARGET_DIR/.agent/commands" ]]; then
  if [[ -z "$DRY_RUN" ]]; then
    mv "$TARGET_DIR/.agent/command" "$TARGET_DIR/.agent/commands"
    log_info "Migrated .agent/command/ to .agent/commands/"
  else
    log_verbose "would migrate .agent/command/ to .agent/commands/"
  fi
elif [[ -d "$TARGET_DIR/.agent/command" && -d "$TARGET_DIR/.agent/commands" ]]; then
  # Both exist, remove old one
  if [[ -z "$DRY_RUN" ]]; then
    rm -rf "$TARGET_DIR/.agent/command"
    log_info "Removed old .agent/command/ (migrated to .agent/commands/)"
  else
    log_verbose "would remove old .agent/command/"
  fi
fi

# Ensure directory exists
if [[ -z "$DRY_RUN" ]]; then
  mkdir -p "$TARGET_DIR/.agent/commands"
fi

# Copy commands to .agent/commands/
for cmd_src in "$OPENCODE_ROOT/command/"*.md; do
  [[ -f "$cmd_src" ]] || continue
  fname="$(basename "$cmd_src")"
  dst="$TARGET_DIR/.agent/commands/$fname"
  if [[ -n "$DRY_RUN" ]]; then
    log_verbose "would copy: $dst"
  else
    cp "$cmd_src" "$dst"
    log_verbose "copied: $dst"
  fi
  UPDATED_COMMANDS=$((UPDATED_COMMANDS + 1))
done

# AIDEV-NOTE: Remove stale commands that no longer exist in the source repo.
# This handles renames (e.g. bug.md -> fix.md) where the old file would
# otherwise linger in the target and confuse the AI with duplicate commands.
REMOVED_COMMANDS=0
for installed_cmd in "$TARGET_DIR/.agent/commands/"*.md; do
  [[ -f "$installed_cmd" ]] || continue
  cmd_name="$(basename "$installed_cmd")"
  if [[ ! -f "$OPENCODE_ROOT/command/$cmd_name" ]]; then
    if [[ -n "$DRY_RUN" ]]; then
      log_verbose "would remove stale command: $cmd_name"
    else
      rm "$installed_cmd"
      log_verbose "removed stale command: $cmd_name"
    fi
    REMOVED_COMMANDS=$((REMOVED_COMMANDS + 1))
  fi
done

# Ensure .opencode -> .agent symlink exists
if [[ -z "$DRY_RUN" ]]; then
  if [[ -L "$TARGET_DIR/.opencode" ]]; then
    # Symlink exists, verify it points to .agent
    link_target="$(readlink "$TARGET_DIR/.opencode")"
    if [[ "$link_target" != ".agent" ]]; then
      rm "$TARGET_DIR/.opencode"
      ln -s .agent "$TARGET_DIR/.opencode"
      log_verbose "fixed symlink: .opencode -> .agent"
    fi
  elif [[ -d "$TARGET_DIR/.opencode" ]]; then
    # Old per-file symlink directory exists, replace with single symlink
    rm -rf "$TARGET_DIR/.opencode"
    ln -s .agent "$TARGET_DIR/.opencode"
    log_verbose "replaced directory with symlink: .opencode -> .agent"
  else
    # No .opencode exists, create symlink
    ln -s .agent "$TARGET_DIR/.opencode"
    log_verbose "created symlink: .opencode -> .agent"
  fi
  if [[ "$REMOVED_COMMANDS" -gt 0 ]]; then
    log_success "Commands synced: $UPDATED_COMMANDS files ($REMOVED_COMMANDS stale removed)"
  else
    log_success "Commands synced: $UPDATED_COMMANDS files"
  fi
else
  log_verbose "would ensure .opencode -> .agent symlink"
  if [[ "$REMOVED_COMMANDS" -gt 0 ]]; then
    log_success "Commands would sync: $UPDATED_COMMANDS files ($REMOVED_COMMANDS stale would be removed)"
  else
    log_success "Commands would sync: $UPDATED_COMMANDS files"
  fi
fi

# ============================================
# Sync Agents (all agents from source)
# ============================================

# AIDEV-NOTE: Sync ALL agents from the source repo's agent/ directory.
# The AI will self-select which agents are relevant based on codebase context.
# This matches how skills are synced (unconditionally) and ensures projects
# always have access to the latest workflow agents without re-running opencode-init.
log_info "Syncing agents..."
UPDATED_AGENTS=0
ADDED_AGENTS=0

# Migrate from old singular to new plural if needed
if [[ -d "$TARGET_DIR/.agent/agent" && ! -d "$TARGET_DIR/.agent/agents" ]]; then
  if [[ -z "$DRY_RUN" ]]; then
    mv "$TARGET_DIR/.agent/agent" "$TARGET_DIR/.agent/agents"
    log_info "Migrated .agent/agent/ to .agent/agents/"
  else
    log_verbose "would migrate .agent/agent/ to .agent/agents/"
  fi
elif [[ -d "$TARGET_DIR/.agent/agent" && -d "$TARGET_DIR/.agent/agents" ]]; then
  # Both exist, remove old one
  if [[ -z "$DRY_RUN" ]]; then
    rm -rf "$TARGET_DIR/.agent/agent"
    log_info "Removed old .agent/agent/ (migrated to .agent/agents/)"
  else
    log_verbose "would remove old .agent/agent/"
  fi
fi

# Ensure agents directory exists
if [[ -z "$DRY_RUN" ]]; then
  mkdir -p "$TARGET_DIR/.agent/agents"
fi

# Sync ALL agents from source repo
for agent_src in "$OPENCODE_ROOT/agent/"*.md; do
  [[ -f "$agent_src" ]] || continue
  agent_name="$(basename "$agent_src")"
  dst_agent="$TARGET_DIR/.agent/agents/$agent_name"
  if [[ -f "$dst_agent" ]]; then
    sync_file "$agent_src" "$dst_agent"
    UPDATED_AGENTS=$((UPDATED_AGENTS + 1))
  else
    if [[ -n "$DRY_RUN" ]]; then
      log_verbose "would install agent: $agent_name"
    else
      cp "$agent_src" "$dst_agent"
      log_verbose "installed: $agent_name"
    fi
    ADDED_AGENTS=$((ADDED_AGENTS + 1))
  fi
done

# Remove stale agents that no longer exist in source repo
# AIDEV-NOTE: This handles agent renames/removals, keeping target in sync with source.
REMOVED_AGENTS=0
for installed_agent in "$TARGET_DIR/.agent/agents/"*.md; do
  [[ -f "$installed_agent" ]] || continue
  agent_name="$(basename "$installed_agent")"
  if [[ ! -f "$OPENCODE_ROOT/agent/$agent_name" ]]; then
    if [[ -n "$DRY_RUN" ]]; then
      log_verbose "would remove stale agent: $agent_name"
    else
      rm "$installed_agent"
      log_verbose "removed stale agent: $agent_name"
    fi
    REMOVED_AGENTS=$((REMOVED_AGENTS + 1))
  fi
done

if [[ "$REMOVED_AGENTS" -gt 0 ]]; then
  log_success "Agents synced: $UPDATED_AGENTS updated, $ADDED_AGENTS added, $REMOVED_AGENTS stale removed"
else
  log_success "Agents synced: $UPDATED_AGENTS updated, $ADDED_AGENTS added"
fi

# ============================================
# Sync Lib
# ============================================

log_info "Syncing lib..."
# Copy all JS files from lib/ (excludes non-workflow data files like go-modernizers.json)
UPDATED_LIB=0
for lib_src in "$OPENCODE_ROOT/lib/"*.js; do
  [[ -f "$lib_src" ]] || continue
  fname="$(basename "$lib_src")"
  sync_file "$lib_src" "$TARGET_DIR/.agent/lib/$fname"
  UPDATED_LIB=$((UPDATED_LIB + 1))
done
log_success "Lib synced: $UPDATED_LIB JS files"

# ============================================
# Sync Backend
# ============================================

log_info "Syncing backend: $BACKEND..."
sync_file "$OPENCODE_ROOT/backends/$BACKEND/index.js"  "$TARGET_DIR/.agent/backends/$BACKEND/index.js"
sync_file "$OPENCODE_ROOT/backends/$BACKEND/README.md" "$TARGET_DIR/.agent/backends/$BACKEND/README.md"
log_success "Backend synced: $BACKEND"

# ============================================
# Sync Skills
# ============================================

# AIDEV-NOTE: All skills are copied unconditionally — they are small markdown
# reference docs loaded on demand by the AI via description-based matching.
# There is zero cost to having all skills present. This matches opencode-init's
# behavior and ensures projects never miss skills added after initial setup.

log_info "Syncing skills..."
UPDATED_SKILLS=0
ADDED_SKILLS=0

# Ensure skills directory exists
if [[ -z "$DRY_RUN" ]]; then
  mkdir -p "$TARGET_DIR/.agent/skills"
fi

for skill_dir in "$OPENCODE_ROOT/skills"/*/; do
  [[ -d "$skill_dir" ]] || continue
  skill_name="$(basename "$skill_dir")"
  src_skill="$skill_dir/SKILL.md"
  [[ -f "$src_skill" ]] || continue

  dst_skill_dir="$TARGET_DIR/.agent/skills/$skill_name"
  dst_skill="$dst_skill_dir/SKILL.md"

  if [[ -d "$dst_skill_dir" ]]; then
    # Update existing skill
    sync_file "$src_skill" "$dst_skill"
    UPDATED_SKILLS=$((UPDATED_SKILLS + 1))
  else
    # Install missing skill
    if [[ -n "$DRY_RUN" ]]; then
      log_verbose "would install missing skill: $skill_name"
    else
      mkdir -p "$dst_skill_dir"
      cp "$src_skill" "$dst_skill"
      log_info "Installed missing skill: $skill_name"
    fi
    ADDED_SKILLS=$((ADDED_SKILLS + 1))
  fi
done

# AIDEV-NOTE: Remove stale skills that no longer exist in source repo.
# This mirrors the stale-removal logic for commands and agents above.
REMOVED_SKILLS=0
for installed_skill_dir in "$TARGET_DIR/.agent/skills"/*/; do
  [[ -d "$installed_skill_dir" ]] || continue
  skill_name="$(basename "$installed_skill_dir")"
  if [[ ! -d "$OPENCODE_ROOT/skills/$skill_name" ]]; then
    if [[ -n "$DRY_RUN" ]]; then
      log_verbose "would remove stale skill: $skill_name"
    else
      rm -rf "$installed_skill_dir"
      log_verbose "removed stale skill: $skill_name"
    fi
    REMOVED_SKILLS=$((REMOVED_SKILLS + 1))
  fi
done

if [[ "$REMOVED_SKILLS" -gt 0 ]]; then
  log_success "Skills synced: $UPDATED_SKILLS updated, $ADDED_SKILLS newly installed, $REMOVED_SKILLS stale removed"
else
  log_success "Skills synced: $UPDATED_SKILLS updated, $ADDED_SKILLS newly installed"
fi

# ============================================
# Summary
# ============================================

echo
if [[ -n "$DRY_RUN" ]]; then
  echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${YELLOW}Dry run complete — no files were changed${NC}"
  echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
else
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${GREEN}✓ opencode-sync complete!${NC}"
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
fi
echo
echo "Updated: commands ($UPDATED_COMMANDS), agents ($UPDATED_AGENTS updated, $ADDED_AGENTS added), skills ($UPDATED_SKILLS updated, $ADDED_SKILLS added)"
echo
if [[ -n "$FORCE" ]]; then
  echo "Force-regenerated:"
