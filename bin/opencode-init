#!/usr/bin/env bash
#
# opencode-init - Initialize OpenCode workflow in a new project
#
# Usage:
#   opencode-init [OPTIONS] [target-dir]
#
# Examples:
#   opencode-init                           # Initialize in current directory with file backend
#   opencode-init ~/projects/myapp          # Initialize in specified directory
#   opencode-init --backend=jira-taskwarrior .  # Jira + Taskwarrior backend
#   opencode-init --stack=backend --lang=go # Backend stack with Go tooling
#   opencode-init --with-startup            # Add flachnetz/startup library dependency
#   opencode-init --scaffold=myservice      # Scaffold a Go service from template
#
# AIDEV-NOTE: This script copies the minimal workflow files needed to use
# OpenCode's /issue, /spec, /createtasks, /implement, /feature, /bug,
# /resume, /status, and /plan commands in a new project.
# All workflow machinery is placed under .agent/ (hidden, gitignored state) and
# specs/ (committed, user-visible). opencode.json and AGENTS.md stay in the root.
# Phase 1 additions: /feature, /bug, /resume, /status + workflow-state.js
# Phase 2 additions: /plan, plan-mode agent, plan-state.js
# Phase E additions: --stack, --skills, --lang for platform engineering setup.
# Phase F additions: --with-startup, --scaffold for Go service scaffolding.

set -euo pipefail

# ============================================
# Configuration
# ============================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OPENCODE_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Defaults
BACKEND="file"
TARGET_DIR="."
STACK=""
SKILLS=""
LANG=""
WITH_STARTUP=""
STARTUP_APPLIED=""   # set to "true" only if add_startup_library succeeds
SCAFFOLD=""

# Available skills by category
# AIDEV-NOTE: Update these arrays when adding new skills
BACKEND_SKILLS=(
  "postgres"
  "kafka"
  "docker"
  "kubernetes"
  "helm"
  "argocd"
  "migrations"
  "observability"
  "cicd"
  "grpc"
)

GO_SKILLS=(
  "coding-standards"
)

RUST_SKILLS=(
  "coding-standards"
)

GO_AGENTS=(
  "debugger-go"
)

RUST_AGENTS=(
  "debugger-rust"
)

# Build/test command defaults per language
# AIDEV-NOTE: These are substituted into the generated AGENTS.md template.
# Implemented as functions (not associative arrays) for bash 3.2 compatibility (macOS).
lang_build_cmd() {
  case "$1" in
    go)      echo "go build ./..." ;;
    rust)    echo "cargo build" ;;
    node)    echo "npm run build" ;;
    python)  echo "python -m build" ;;
    *)       echo "<fill in your build command>" ;;
  esac
}
lang_test_cmd() {
  case "$1" in
    go)      echo "go test ./..." ;;
    rust)    echo "cargo test" ;;
    node)    echo "npm test" ;;
    python)  echo "pytest" ;;
    *)       echo "<fill in your test command>" ;;
  esac
}
lang_lint_cmd() {
  case "$1" in
    go)      echo "golangci-lint run ./..." ;;
    rust)    echo "cargo clippy -- -D warnings" ;;
    node)    echo "npm run lint" ;;
    python)  echo "ruff check ." ;;
    *)       echo "<fill in your lint command>" ;;
  esac
}
lang_single_test_cmd() {
  case "$1" in
    go)      echo "go test ./path/to/package/..." ;;
    rust)    echo "cargo test test_name" ;;
    node)    echo "npm test -- --testPathPattern=<pattern>" ;;
    python)  echo "pytest path/to/test_file.py" ;;
    *)       echo "<fill in your single-test command>" ;;
  esac
}

# Colors (if terminal supports them)
if [[ -t 1 ]]; then
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[0;33m'
  BLUE='\033[0;34m'
  NC='\033[0m' # No Color
else
  RED=''
  GREEN=''
  YELLOW=''
  BLUE=''
  NC=''
fi

# ============================================
# Helper Functions
# ============================================

log_info() {
  echo -e "${BLUE}ℹ${NC} $1"
}

log_success() {
  echo -e "${GREEN}✓${NC} $1"
}

log_warn() {
  echo -e "${YELLOW}⚠${NC} $1"
}

log_error() {
  echo -e "${RED}✗${NC} $1" >&2
}

usage() {
  cat <<EOF
Usage: opencode-init [OPTIONS] [target-dir]

Initialize OpenCode workflow in a project directory.

Options:
  --backend=TYPE    Workflow backend: file (default), beads, or jira-taskwarrior
  --stack=PRESET    Stack preset: backend (includes infra skills)
  --skills=LIST     Comma-separated skills to copy (e.g., postgres,kafka,docker)
  --lang=LANG       Language tooling: go, rust, node, python, both,
                    or any custom language (e.g. swift, elixir)
  --with-startup    Add flachnetz/startup library (runs go get if go.mod exists)
  --scaffold[=NAME] Scaffold a Go service from template (default name: service)
  --help, -h        Show this help message
  --list-skills     List all available skills

Arguments:
  target-dir        Directory to initialize (default: current directory)

Examples:
  opencode-init                                    # Init with file backend only
  opencode-init --stack=backend                    # Init with all backend infra skills
  opencode-init --stack=backend --lang=go          # Backend + Go tooling
  opencode-init --skills=postgres,docker           # Only specific skills
  opencode-init --lang=rust                        # Only Rust debugger + coding standards
  opencode-init --backend=jira-taskwarrior         # Jira + Taskwarrior backend
  opencode-init --with-startup                     # Add startup library to existing go.mod
  opencode-init --scaffold=myapi                   # Scaffold Go service named 'myapi'
  opencode-init --scaffold --with-startup          # Scaffold with startup library

Backends:
  file              Zero-dependency local workflow (default, recommended)
                    Sequential IDs (ISSUE-1, ISSUE-2), state in .agent/state/
                    Best for: solo developers, simple projects, getting started
  beads             Beads (bd) local-first task manager
                    Best for: individuals wanting lightweight local workflow
  jira-taskwarrior  Jira + Taskwarrior integration (for teams with Jira)
                    Best for: teams already using Jira, rich dependency tracking

Stack Presets:
  backend           All backend infrastructure skills:
                    postgres, kafka, docker, kubernetes, helm, argocd,
                    migrations, observability, cicd, grpc

Language Tooling:
  go                Go coding standards + debugger agent
  rust              Rust coding standards + debugger agent
  node              Node.js / TypeScript tooling
  python            Python tooling
  both              Both Go and Rust tooling
  <custom>          Any other language (e.g. swift, elixir, java)
                    Stored in .agent/config.json; use /generate-lang-skills
                    inside OpenCode to create custom skills for it

Scaffolding:
  --scaffold        Creates a complete Go service from templates/go-service/
                    Uses flachnetz/startup for bootstrapping with:
                    - Postgres connection with migrations
                    - HTTP server with admin panel
                    - Prometheus metrics
                    - Graceful shutdown

EOF
  exit 0
}

list_skills() {
  echo "Available skills:"
  echo
  echo "Backend Infrastructure:"
  for skill in "${BACKEND_SKILLS[@]}"; do
    echo "  - $skill"
  done
  echo
  echo "Language-specific (included via --lang):"
  echo "  Go:   coding-standards, debugger-go agent"
  echo "  Rust: coding-standards, debugger-rust agent"
  echo
  echo "Other skills in repository:"
  for skill_path in "$OPENCODE_ROOT"/skills/*/SKILL.md; do
    skill_name=$(basename "$(dirname "$skill_path")")
    # Skip if already listed
    if [[ ! " ${BACKEND_SKILLS[*]} " =~ " ${skill_name} " ]] && \
       [[ "$skill_name" != "coding-standards" ]] && \
       [[ "$skill_name" != "workflow-backend" ]]; then
      echo "  - $skill_name"
    fi
  done
  exit 0
}

# Copy a skill directory into .agent/skills/
copy_skill() {
  local skill_name="$1"
  local skill_src="$OPENCODE_ROOT/skills/$skill_name"
  local skill_dst="$TARGET_DIR/.agent/skills/$skill_name"

  if [[ -d "$skill_src" ]]; then
    mkdir -p "$skill_dst"
    cp "$skill_src/SKILL.md" "$skill_dst/"
    log_success "Copied skill: $skill_name"
  else
    log_warn "Skill not found: $skill_name"
  fi
}

# Copy an agent file into .agent/agent/
copy_agent() {
  local agent_name="$1"
  local agent_src="$OPENCODE_ROOT/agent/$agent_name.md"
  local agent_dst="$TARGET_DIR/.agent/agent/$agent_name.md"

  if [[ -f "$agent_src" ]]; then
    cp "$agent_src" "$agent_dst"
    log_success "Copied agent: $agent_name"
  else
    log_warn "Agent not found: $agent_name"
  fi
}

# AIDEV-NOTE: scaffold_service copies templates/go-service/ to target,
# substituting {{.Module}} and {{.ServiceName}} placeholders.
scaffold_service() {
  local service_name="$1"
  local template_src="$OPENCODE_ROOT/templates/go-service"
  local service_dst="$TARGET_DIR"

  if [[ ! -d "$template_src" ]]; then
    log_error "Template not found: $template_src"
    return 1
  fi

  # Detect module path from existing go.mod or derive from directory
  local module_path
  if [[ -f "$service_dst/go.mod" ]]; then
    module_path=$(grep "^module " "$service_dst/go.mod" | awk '{print $2}')
    log_info "Using existing module: $module_path"
  else
    # Use directory name as module path base
    module_path="github.com/$(basename "$service_dst")"
    log_info "Using derived module path: $module_path"
  fi

  log_info "Scaffolding service '$service_name' from template..."

  # Create directory structure
  mkdir -p "$service_dst/cmd/server"
  mkdir -p "$service_dst/internal/handler"
  mkdir -p "$service_dst/internal/repository"
  mkdir -p "$service_dst/internal/service"
  mkdir -p "$service_dst/sql"

  # Process template files with variable substitution
  # Using sed for {{.Module}} and {{.ServiceName}} replacement
  local files_to_process=(
    "cmd/server/main.go"
    "internal/handler/handler.go"
    "internal/repository/repository.go"
    "internal/service/service.go"
  )

  for file in "${files_to_process[@]}"; do
    if [[ -f "$template_src/$file" ]]; then
      sed -e "s|{{\.Module}}|$module_path|g" \
          -e "s|{{\.ServiceName}}|$service_name|g" \
          "$template_src/$file" > "$service_dst/$file"
      log_success "Created: $file"
    fi
  done

  # Copy non-template files directly
  local files_to_copy=(
    "sql/001_initial.sql"
    "Dockerfile"
    "docker-compose.yml"
    "Makefile"
    ".gitignore"
  )

  for file in "${files_to_copy[@]}"; do
    if [[ -f "$template_src/$file" ]]; then
      # Ensure parent directory exists
      mkdir -p "$(dirname "$service_dst/$file")"
      cp "$template_src/$file" "$service_dst/$file"
      log_success "Copied: $file"
    fi
  done

  # Process go.mod.tmpl if no go.mod exists
  if [[ ! -f "$service_dst/go.mod" ]] && [[ -f "$template_src/go.mod.tmpl" ]]; then
    sed -e "s|{{\.Module}}|$module_path|g" \
        "$template_src/go.mod.tmpl" > "$service_dst/go.mod"
    log_success "Created: go.mod"
  fi

  # Copy README with substitution
  if [[ -f "$template_src/README.md" ]]; then
    sed -e "s|{{\.Module}}|$module_path|g" \
        -e "s|{{\.ServiceName}}|$service_name|g" \
        "$template_src/README.md" > "$service_dst/README.md"
    log_success "Created: README.md"
  fi

  log_success "Service scaffolded: $service_name"
}

# Add startup library to go.mod
add_startup_library() {
  if [[ ! -f "$TARGET_DIR/go.mod" ]]; then
    log_warn "No go.mod found. Skipping --with-startup (run 'go mod init' first or use --scaffold)"
    return 1
  fi

  log_info "Adding flachnetz/startup library..."

  (cd "$TARGET_DIR" && go get github.com/flachnetz/startup/v2@latest)

  if [[ $? -eq 0 ]]; then
    log_success "Added: github.com/flachnetz/startup/v2"

    # Also add common sub-packages
    (cd "$TARGET_DIR" && go get \
      github.com/flachnetz/startup/v2/startup_base@latest \
      github.com/flachnetz/startup/v2/startup_http@latest \
      github.com/flachnetz/startup/v2/startup_postgres@latest \
      2>/dev/null) || true

    log_success "Added startup sub-packages (base, http, postgres)"
  else
    log_error "Failed to add startup library"
    return 1
  fi

  # Copy the startup skill
  copy_skill "startup"
  STARTUP_APPLIED="true"
}

# AIDEV-NOTE: Generates AGENTS.md from the template by substituting
# {{PROJECT_NAME}}, {{BUILD_CMD}}, {{TEST_CMD}}, {{LINT_CMD}}, {{SINGLE_TEST_CMD}}.
# lang_key is one of: go, rust, node, python, default.
generate_agents_md() {
  local project_name="$1"
  local lang_key="$2"
  local template_src="$OPENCODE_ROOT/templates/AGENTS.md.tmpl"
  local agents_md_dst="$TARGET_DIR/AGENTS.md"

  if [[ ! -f "$template_src" ]]; then
    log_warn "AGENTS.md template not found: $template_src — skipping generation"
    return 0
  fi

  # Resolve commands for the given lang key, falling back to "default"
  local build_cmd; build_cmd="$(lang_build_cmd "$lang_key")"
  local test_cmd;  test_cmd="$(lang_test_cmd  "$lang_key")"
  local lint_cmd;  lint_cmd="$(lang_lint_cmd  "$lang_key")"
  local single_test_cmd; single_test_cmd="$(lang_single_test_cmd "$lang_key")"

  sed \
    -e "s|{{PROJECT_NAME}}|$project_name|g" \
    -e "s|{{BUILD_CMD}}|$build_cmd|g" \
    -e "s|{{TEST_CMD}}|$test_cmd|g" \
    -e "s|{{LINT_CMD}}|$lint_cmd|g" \
    -e "s|{{SINGLE_TEST_CMD}}|$single_test_cmd|g" \
    "$template_src" > "$agents_md_dst"

  log_success "Generated AGENTS.md (lang: $lang_key)"
}

# ============================================
# Argument Parsing
# ============================================

while [[ $# -gt 0 ]]; do
  case "$1" in
    --backend=*)
      BACKEND="${1#*=}"
      shift
      ;;
    --backend)
      BACKEND="$2"
      shift 2
      ;;
    --stack=*)
      STACK="${1#*=}"
      shift
      ;;
    --stack)
      STACK="$2"
      shift 2
      ;;
    --skills=*)
      SKILLS="${1#*=}"
      shift
      ;;
    --skills)
      SKILLS="$2"
      shift 2
      ;;
    --lang=*)
      LANG="${1#*=}"
      shift
      ;;
    --lang)
      LANG="$2"
      shift 2
      ;;
    --with-startup)
      WITH_STARTUP="true"
      shift
      ;;
    --scaffold=*)
      SCAFFOLD="${1#*=}"
      shift
      ;;
    --scaffold)
      # Default service name if not specified
      SCAFFOLD="service"
      shift
      ;;
    --list-skills)
      list_skills
      ;;
    --help|-h)
      usage
      ;;
    -*)
      log_error "Unknown option: $1"
      echo "Run 'opencode-init --help' for usage."
      exit 1
      ;;
    *)
      TARGET_DIR="$1"
      shift
      ;;
  esac
done

# Validate backend
if [[ "$BACKEND" != "file" && "$BACKEND" != "beads" && "$BACKEND" != "jira-taskwarrior" ]]; then
  log_error "Invalid backend: $BACKEND"
  echo "Valid backends: file, beads, jira-taskwarrior"
  exit 1
fi

# Validate stack
if [[ -n "$STACK" && "$STACK" != "backend" ]]; then
  log_error "Invalid stack: $STACK"
  echo "Valid stacks: backend"
  exit 1
fi

# Validate lang — known langs get specific tooling; unknown langs get a warning
# and a prompt to generate skills via /generate-lang-skills after init.
# AIDEV-NOTE: We intentionally do NOT exit on unknown lang. Unknown langs are
# stored in .agent/config.json so opencode-sync and /generate-lang-skills can
# pick them up later.
KNOWN_LANGS=("go" "rust" "node" "python" "both")
LANG_IS_KNOWN=""
if [[ -n "$LANG" ]]; then
  for kl in "${KNOWN_LANGS[@]}"; do
    if [[ "$LANG" == "$kl" ]]; then
      LANG_IS_KNOWN="true"
      break
    fi
  done
  if [[ -z "$LANG_IS_KNOWN" ]]; then
    log_warn "Unknown language: '$LANG' — no built-in tooling for this language."
    log_warn "Your language will be stored in .agent/config.json."
    log_warn "After init you can run /generate-lang-skills to create custom skills."
  fi
fi

# ============================================
# Pre-flight Checks
# ============================================

log_info "Initializing OpenCode workflow with backend: ${BLUE}$BACKEND${NC}"
[[ -n "$STACK" ]] && log_info "Stack preset: ${BLUE}$STACK${NC}"
[[ -n "$LANG" ]] && log_info "Language tooling: ${BLUE}$LANG${NC}"
[[ -n "$SKILLS" ]] && log_info "Additional skills: ${BLUE}$SKILLS${NC}"
[[ -n "$SCAFFOLD" ]] && log_info "Scaffold service: ${BLUE}$SCAFFOLD${NC}"
[[ -n "$WITH_STARTUP" ]] && log_info "With startup library: ${BLUE}yes${NC}"

# Check target directory
if [[ ! -d "$TARGET_DIR" ]]; then
  log_info "Creating directory: $TARGET_DIR"
  mkdir -p "$TARGET_DIR"
fi

TARGET_DIR="$(cd "$TARGET_DIR" && pwd)"
log_info "Target directory: $TARGET_DIR"

# Check if already initialized
if [[ -f "$TARGET_DIR/.agent/config.json" ]]; then
  log_warn ".agent/config.json already exists in target directory"
  read -p "Overwrite? [y/N] " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    log_info "Aborted."
    exit 0
  fi
fi

# Check backend prerequisites
if [[ "$BACKEND" == "jira-taskwarrior" ]]; then
  if ! command -v task &> /dev/null; then
    log_warn "Taskwarrior (task) not found. Install with: brew install task"
  fi
  if ! command -v acli &> /dev/null; then
    log_warn "Atlassian CLI (acli) not found. See: https://developer.atlassian.com/cloud/acli/"
  fi
fi

if [[ "$BACKEND" == "beads" ]]; then
  if ! command -v bd &> /dev/null; then
    log_warn "Beads CLI (bd) not found. See: backends/beads/README.md for installation"
  fi
fi

# Check Go prerequisites for --with-startup and --scaffold
if [[ -n "$WITH_STARTUP" || -n "$SCAFFOLD" ]]; then
  if ! command -v go &> /dev/null; then
    log_error "Go is required for --with-startup and --scaffold options"
    log_info "Install Go from: https://go.dev/dl/"
    exit 1
  fi
fi

# ============================================
# Copy Files into .agent/
# ============================================

log_info "Copying workflow files into .agent/ ..."

# Create .agent/ directory structure
mkdir -p "$TARGET_DIR/.agent/command"
mkdir -p "$TARGET_DIR/.agent/agent"
mkdir -p "$TARGET_DIR/.agent/skills/workflow-backend"
mkdir -p "$TARGET_DIR/.agent/backends/$BACKEND"
mkdir -p "$TARGET_DIR/.agent/lib"
mkdir -p "$TARGET_DIR/.agent/templates"
# specs/ and plans/ live in the project root (committed to git)
mkdir -p "$TARGET_DIR/specs"
mkdir -p "$TARGET_DIR/plans"
touch "$TARGET_DIR/plans/.gitkeep"

# Copy all commands (entire directory)
cp "$OPENCODE_ROOT/command/"*.md "$TARGET_DIR/.agent/command/"
log_success "Copied all commands ($(ls "$OPENCODE_ROOT/command/"*.md | wc -l | tr -d ' ') files)"

# Copy core agents (selective — agent/ contains many project-specific extras)
cp "$OPENCODE_ROOT/agent/spec-mode.md"     "$TARGET_DIR/.agent/agent/"
cp "$OPENCODE_ROOT/agent/create-tasks.md"  "$TARGET_DIR/.agent/agent/"
cp "$OPENCODE_ROOT/agent/plan-mode.md"     "$TARGET_DIR/.agent/agent/"
cp "$OPENCODE_ROOT/agent/build.md"         "$TARGET_DIR/.agent/agent/"
cp "$OPENCODE_ROOT/agent/test-agent.md"    "$TARGET_DIR/.agent/agent/"
cp "$OPENCODE_ROOT/agent/code-reviewer.md" "$TARGET_DIR/.agent/agent/"
log_success "Copied core agents (6 files)"

# Copy workflow skill
cp "$OPENCODE_ROOT/skills/workflow-backend/SKILL.md" "$TARGET_DIR/.agent/skills/workflow-backend/"
log_success "Copied skill: workflow-backend"

# Copy backend
cp "$OPENCODE_ROOT/backends/$BACKEND/index.js"  "$TARGET_DIR/.agent/backends/$BACKEND/"
cp "$OPENCODE_ROOT/backends/$BACKEND/README.md" "$TARGET_DIR/.agent/backends/$BACKEND/"
log_success "Copied backend: $BACKEND"

# Copy lib JS files only (lib/ also contains non-workflow data files like go-modernizers.json)
cp "$OPENCODE_ROOT/lib/"*.js "$TARGET_DIR/.agent/lib/"
log_success "Copied lib ($(ls "$OPENCODE_ROOT/lib/"*.js | wc -l | tr -d ' ') JS files)"

# Copy templates used by commands
cp "$OPENCODE_ROOT/templates/generate-lang-skills.md.tmpl" "$TARGET_DIR/.agent/templates/"
log_success "Copied templates: generate-lang-skills"

# Copy interface (for reference)
cp "$OPENCODE_ROOT/backends/interface.ts" "$TARGET_DIR/.agent/backends/"
log_success "Copied interface definition"

# ============================================
# Copy Stack Skills
# ============================================

if [[ "$STACK" == "backend" ]]; then
  log_info "Copying backend stack skills..."
  for skill in "${BACKEND_SKILLS[@]}"; do
    copy_skill "$skill"
  done
fi

# ============================================
# Copy Individual Skills
# ============================================

if [[ -n "$SKILLS" ]]; then
  log_info "Copying selected skills..."
  IFS=',' read -ra SKILL_ARRAY <<< "$SKILLS"
  for skill in "${SKILL_ARRAY[@]}"; do
    # Trim whitespace
    skill=$(echo "$skill" | xargs)
    copy_skill "$skill"
  done
fi

# ============================================
# Copy Language Tooling
# ============================================

if [[ "$LANG" == "go" || "$LANG" == "both" ]]; then
  log_info "Copying Go tooling..."
  for skill in "${GO_SKILLS[@]}"; do
    copy_skill "$skill"
  done
  for agent in "${GO_AGENTS[@]}"; do
    copy_agent "$agent"
  done
fi

if [[ "$LANG" == "rust" || "$LANG" == "both" ]]; then
  log_info "Copying Rust tooling..."
  for skill in "${RUST_SKILLS[@]}"; do
    copy_skill "$skill"
  done
  for agent in "${RUST_AGENTS[@]}"; do
    copy_agent "$agent"
  done
fi

# ============================================
# Scaffold Go Service
# ============================================

if [[ -n "$SCAFFOLD" ]]; then
  # AIDEV-NOTE: || true prevents set -e abort if template is missing.
  scaffold_service "$SCAFFOLD" || true
fi

# ============================================
# Add Startup Library
# ============================================

if [[ -n "$WITH_STARTUP" ]]; then
  # AIDEV-NOTE: || true prevents set -e from aborting the script when
  # add_startup_library returns 1 (e.g. no go.mod found). The function
  # already emits a log_warn in that case; generation must continue.
  add_startup_library || true
fi

# ============================================
# Generate opencode.json (project root)
# ============================================

# ============================================
# Generate .agent/config.json (workflow backend config)
# ============================================
# AIDEV-NOTE: Backend config lives in .agent/config.json, NOT opencode.json.
# The upstream OpenCode binary rejects unknown top-level keys in opencode.json,
# so we keep workflow config separate.

log_info "Generating .agent/config.json..."

# Build optional language line to inject into config.json
# AIDEV-NOTE: "language" is stored for both known and unknown langs so that
# opencode-sync and /generate-lang-skills can read it later.
LANG_LINE=""
if [[ -n "$LANG" ]]; then
  LANG_LINE="  \"language\": \"$LANG\","
fi

if [[ "$BACKEND" == "file" ]]; then
  cat > "$TARGET_DIR/.agent/config.json" <<EOF
{
${LANG_LINE:+$LANG_LINE
}  "backend": {
    "type": "file",
    "config": {}
  }
}
EOF
elif [[ "$BACKEND" == "beads" ]]; then
  cat > "$TARGET_DIR/.agent/config.json" <<EOF
{
${LANG_LINE:+$LANG_LINE
}  "backend": {
    "type": "beads",
    "config": {
      "workspaceDir": "$TARGET_DIR",
      "beadsDir": "$TARGET_DIR/.beads",
      "lmmNotesRoot": "$TARGET_DIR/notes"
    }
  }
}
EOF
  log_warn "Run 'bd init --stealth' in your project root before using the beads backend"
elif [[ "$BACKEND" == "jira-taskwarrior" ]]; then
  cat > "$TARGET_DIR/.agent/config.json" <<EOF
{
${LANG_LINE:+$LANG_LINE
}  "backend": {
    "type": "jira-taskwarrior",
    "config": {
      "jiraSite": "YOUR_ORG.atlassian.net",
      "jiraProject": "YOUR_PROJECT_KEY",
      "jiraEmail": "your.email@example.com",
      "taskrcPath": "~/.taskrc",
      "taskDataLocation": "~/.task",
      "lmmNotesRoot": "./notes"
    }
  }
}
EOF
  log_warn "Edit .agent/config.json to configure your Jira site and project"
fi

log_success "Generated .agent/config.json"

# ============================================
# Generate opencode.json (project root)
# ============================================
# AIDEV-NOTE: opencode.json only contains keys the upstream OpenCode binary
# accepts ($schema, provider, agent, instructions, permission, mcp).
# Workflow/backend config is in .agent/config.json instead.

log_info "Generating opencode.json..."

cat > "$TARGET_DIR/opencode.json" <<'EOF'
{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md"
  ]
}
EOF

log_success "Generated opencode.json"

# ============================================
# Generate AGENTS.md (project root)
# ============================================

log_info "Generating AGENTS.md..."

PROJECT_NAME="$(basename "$TARGET_DIR")"

# Determine lang key for template substitution
AGENTS_LANG_KEY="default"
if [[ "$LANG" == "go" || "$LANG" == "both" ]]; then
  AGENTS_LANG_KEY="go"
elif [[ "$LANG" == "rust" ]]; then
  AGENTS_LANG_KEY="rust"
elif [[ "$LANG" == "node" ]]; then
  AGENTS_LANG_KEY="node"
elif [[ "$LANG" == "python" ]]; then
  AGENTS_LANG_KEY="python"
fi

generate_agents_md "$PROJECT_NAME" "$AGENTS_LANG_KEY"

# ============================================
# Update .gitignore
# ============================================

GITIGNORE="$TARGET_DIR/.gitignore"
if [[ -f "$GITIGNORE" ]]; then
  if ! grep -q "# OpenCode" "$GITIGNORE"; then
    log_info "Adding OpenCode entries to .gitignore..."
    cat >> "$GITIGNORE" <<'EOF'

# OpenCode
.agent/state/       # workflow runtime state (issues, tasks, counters)
EOF
    log_success "Updated .gitignore"
  fi
else
  log_info "Creating .gitignore..."
  cat > "$GITIGNORE" <<'EOF'
# OpenCode
.agent/state/       # workflow runtime state (issues, tasks, counters)
EOF
  log_success "Created .gitignore"
fi

# ============================================
# Summary
# ============================================

echo
echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}✓ OpenCode workflow initialized successfully!${NC}"
echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo
echo "Directory: $TARGET_DIR"
echo "Backend:   $BACKEND"
[[ -n "$STACK" ]] && echo "Stack:     $STACK"
[[ -n "$LANG" ]] && echo "Language:  $LANG"
[[ -n "$SCAFFOLD" ]] && echo "Scaffold:  $SCAFFOLD"
[[ -n "$WITH_STARTUP" ]] && echo "Startup:   enabled"
echo
echo "Files created:"
echo "  opencode.json                  - OpenCode configuration (instructions, providers)"
echo "  .agent/config.json             - Workflow backend configuration"
echo "  AGENTS.md                      - AI assistant context (customize me!)"
echo "  specs/                         - Spec documents (committed to git)"
echo "  plans/                         - Backlog markdowns from /plan (committed to git)"
echo "  .agent/command/plan.md         - /plan      brainstorm & bulk-create a backlog"
echo "  .agent/command/feature.md      - /feature   full lifecycle orchestrator"
echo "  .agent/command/bug.md          - /bug        alias for /feature --type=bug"
echo "  .agent/command/resume.md       - /resume     pick up where you left off"
echo "  .agent/command/status.md       - /status     view all active work items"
echo "  .agent/command/issue.md        - /issue      create a new issue"
echo "  .agent/command/spec.md         - /spec       draft & approve a spec"
echo "  .agent/command/createtasks.md  - /createtasks   break spec into tasks"
echo "  .agent/command/implement.md    - /implement     execute tasks"
echo "  .agent/command/git.md          - /git        commit staged changes"
echo "  .agent/command/test.md         - /test       run tests with coverage"
echo "  .agent/command/codereview.md   - /codereview review the current diff"
echo "  .agent/command/PR-summary.md   - /PR-summary write a PR description"
echo "  .agent/agent/spec-mode.md      - Spec writing agent"
echo "  .agent/agent/create-tasks.md   - Task creation agent"
echo "  .agent/agent/plan-mode.md      - Planning / brainstorming agent"
echo "  .agent/agent/build.md          - Implementation / coding agent"
echo "  .agent/agent/test-agent.md     - Test runner subagent"
echo "  .agent/agent/code-reviewer.md  - Code review agent"
echo "  .agent/backends/$BACKEND/      - Backend implementation"
echo "  .agent/lib/backend-loader.js   - Backend loader utility"
echo "  .agent/lib/workflow-state.js   - Workflow state persistence"
echo "  .agent/lib/plan-state.js       - Plan state persistence"

if [[ "$STACK" == "backend" ]]; then
  echo
  echo "Backend stack skills (.agent/skills/):"
  for skill in "${BACKEND_SKILLS[@]}"; do
    echo "  $skill/"
  done
fi

if [[ "$LANG" == "go" || "$LANG" == "both" ]]; then
  echo
  echo "Go tooling:"
  echo "  .agent/skills/coding-standards/  - Go coding standards"
  echo "  .agent/agent/debugger-go.md      - Go debugger agent"
fi

if [[ "$LANG" == "rust" || "$LANG" == "both" ]]; then
  echo
  echo "Rust tooling:"
  echo "  .agent/skills/coding-standards/  - Rust coding standards"
  echo "  .agent/agent/debugger-rust.md    - Rust debugger agent"
fi

if [[ -n "$SCAFFOLD" ]]; then
  echo
  echo "Scaffolded service '$SCAFFOLD':"
  echo "  cmd/server/main.go         - Entry point with startup bootstrap"
  echo "  internal/handler/          - HTTP handlers"
  echo "  internal/repository/       - Database access"
  echo "  internal/service/          - Business logic"
  echo "  sql/                       - Database migrations"
  echo "  Dockerfile                 - Multi-stage build"
  echo "  docker-compose.yml         - Local development"
  echo "  Makefile                   - Build targets"
fi

if [[ -n "$STARTUP_APPLIED" ]]; then
  echo
  echo "Startup library:"
  echo "  .agent/skills/startup/     - Startup library patterns"
  echo "  go.mod                     - Updated with startup deps"
fi

echo
echo -e "${BLUE}Next steps:${NC}"
if [[ -n "$SCAFFOLD" ]]; then
  echo "  1. Initialize deps:    go mod tidy"
  echo "  2. Start database:     docker-compose up -d postgres"
  echo "  3. Run service:        make run"
  echo "  4. View admin panel:   http://localhost:8080/admin"
  echo
  echo "Or use OpenCode workflow:"
elif [[ "$BACKEND" == "beads" ]]; then
  STEP=1
  echo "  $STEP. Initialize Beads:   bd init --stealth"; STEP=$((STEP+1))
  echo "  $STEP. Verify:             bd list";            STEP=$((STEP+1))
  if [[ -n "$WITH_STARTUP" && -z "$STARTUP_APPLIED" ]]; then
    echo "  $STEP. Init Go module:     go mod init <module-path>"; STEP=$((STEP+1))
    echo "  $STEP. Add startup lib:    opencode-init --with-startup (re-run in project root)"; STEP=$((STEP+1))
  fi
  echo
elif [[ "$BACKEND" == "jira-taskwarrior" ]]; then
  echo "  1. Edit .agent/config.json with your Jira site/project"
  echo "  2. Authenticate:       acli jira auth"
  echo
fi
echo "  Full lifecycle (recommended):"
echo "    /plan    \"improve onboarding\"  Brainstorm & bulk-create a backlog"
echo "    /feature ISSUE-1               Start issue → spec → tasks → implement"
echo "    /bug     ISSUE-2               Same flow, tuned for bug fixes"
echo "    /resume  ISSUE-1               Pick up where you left off"
echo "    /status                        View all active work items"
echo
echo "  Step-by-step:"
echo "    /issue \"description\"       Create a new issue"
echo "    /spec  ISSUE-1             Draft and approve a spec"
echo "    /createtasks ISSUE-1       Break spec into implementation tasks"
echo "    /implement   ISSUE-1       Execute tasks"
echo
echo "Tip: Edit AGENTS.md to add project-specific context for the AI."
echo "Documentation: $TARGET_DIR/.agent/backends/$BACKEND/README.md"
echo

# ============================================
# Unknown language post-init prompt
# ============================================

# AIDEV-NOTE: When --lang=<custom> is given (e.g. swift, elixir), there are
# no built-in skills. We prompt the user to either generate skills now via
# /generate-lang-skills inside OpenCode, or skip and do it later.
if [[ -n "$LANG" && -z "$LANG_IS_KNOWN" ]]; then
  echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${YELLOW}Unknown language: $LANG${NC}"
  echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo
  echo "No built-in skills exist for '$LANG', but OpenCode can generate them."
  echo "The /generate-lang-skills command will create custom coding-standards"
  echo "and debugger skills tailored to $LANG."
  echo
  echo "Options:"
  echo "  [g] Generate skills now — open OpenCode and run /generate-lang-skills $LANG"
  echo "  [s] Skip — I'll generate skills later with /generate-lang-skills $LANG"
  echo "  [q] Quit"
  echo
  read -p "Choice [g/s/q]: " -n 1 -r LANG_CHOICE
  echo
  case "$LANG_CHOICE" in
    g|G)
      echo
      log_info "Open OpenCode in $TARGET_DIR and run:"
      echo
      echo "  /generate-lang-skills $LANG"
      echo
      echo "This will generate .agent/skills/coding-standards/ and"
      echo ".agent/agent/debugger-${LANG}.md customized for $LANG."
      ;;
    q|Q)
      log_info "Exiting. Run /generate-lang-skills $LANG inside OpenCode when ready."
      exit 0
      ;;
    *)
      log_info "Skipped. Run /generate-lang-skills $LANG inside OpenCode when ready."
      ;;
  esac
  echo
fi
