fi

echo
echo -e "${BLUE}Next steps:${NC}"
if [[ "$BACKEND" == "beads" ]]; then
  # Beads init is now automatic, just show verification step
  STEP=1
  if ! command -v bd &> /dev/null; then
    echo "  $STEP. Install Beads:      See backends/beads/README.md"; STEP=$((STEP+1))
    echo "  $STEP. Initialize Beads:   bd init --stealth"; STEP=$((STEP+1))
  fi
  echo "  $STEP. Verify:             bd list"; STEP=$((STEP+1))
  if [[ -n "$WITH_STARTUP" && -z "$STARTUP_APPLIED" ]]; then
    echo "  $STEP. Init Go module:     go mod init <module-path>"; STEP=$((STEP+1))
    echo "  $STEP. Add startup lib:    opencode-init --with-startup (re-run in project root)"; STEP=$((STEP+1))
  fi
  echo
elif [[ "$BACKEND" == "jira-taskwarrior" ]]; then
  echo "  1. Edit .agent/config.json with your Jira site/project"
  echo "  2. Authenticate:       acli jira auth"
  echo
fi
echo "  Full lifecycle (recommended):"
echo "    /plan    \"improve onboarding\"  Brainstorm & bulk-create a backlog"
echo "    /feature ISSUE-1               Start issue → tasks → implement"
echo "    /fix     ISSUE-2               Same flow, tuned for bug fixes"
echo "    /resume  ISSUE-1               Pick up where you left off"
echo "    /status                        View all active work items"
echo
echo "  YOLO mode (skip all approval gates, execute end-to-end):"
echo "    /feature ISSUE-1 --yolo        Full lifecycle, no stops"
echo "    /fix     ISSUE-2 --yolo        Bug fix lifecycle, no stops"
echo "    /resume  ISSUE-1 --yolo        Upgrade running workflow to YOLO"
echo
echo "  Step-by-step:"
echo "    /issue \"description\"       Create a new issue"
echo "    /createtasks ISSUE-1       Break issue into implementation tasks"
echo "    /implement   ISSUE-1       Execute tasks"
echo
