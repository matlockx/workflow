#!/usr/bin/env bash
#
# opencode-init - Initialize OpenCode workflow in a new project
#
# Usage:
#   opencode-init [OPTIONS] [target-dir]
#
# Examples:
#   opencode-init                           # Initialize in current directory with Beads
#   opencode-init ~/projects/myapp          # Initialize in specified directory
#   opencode-init --backend=beads .         # Explicit backend selection
#   opencode-init --stack=backend --lang=go # Backend stack with Go tooling
#   opencode-init --with-startup            # Add flachnetz/startup library dependency
#   opencode-init --scaffold=myservice      # Scaffold a Go service from template
#
# AIDEV-NOTE: This script copies the minimal workflow files needed to use
# OpenCode's /spec, /createtasks, and /implement commands in a new project.
# Phase E additions: --stack, --skills, --lang for platform engineering setup.
# Phase F additions: --with-startup, --scaffold for Go service scaffolding.

set -euo pipefail

# ============================================
# Configuration
# ============================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OPENCODE_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Defaults
BACKEND="beads"
TARGET_DIR="."
STACK=""
SKILLS=""
LANG=""
WITH_STARTUP=""
SCAFFOLD=""

# Available skills by category
# AIDEV-NOTE: Update these arrays when adding new skills
BACKEND_SKILLS=(
  "postgres"
  "kafka"
  "docker"
  "kubernetes"
  "helm"
  "argocd"
  "migrations"
  "observability"
  "cicd"
  "grpc"
)

GO_SKILLS=(
  "coding-standards"
)

RUST_SKILLS=(
  "coding-standards"
)

GO_AGENTS=(
  "debugger-go"
)

RUST_AGENTS=(
  "debugger-rust"
)

# Colors (if terminal supports them)
if [[ -t 1 ]]; then
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[0;33m'
  BLUE='\033[0;34m'
  NC='\033[0m' # No Color
else
  RED=''
  GREEN=''
  YELLOW=''
  BLUE=''
  NC=''
fi

# ============================================
# Helper Functions
# ============================================

log_info() {
  echo -e "${BLUE}ℹ${NC} $1"
}

log_success() {
  echo -e "${GREEN}✓${NC} $1"
}

log_warn() {
  echo -e "${YELLOW}⚠${NC} $1"
}

log_error() {
  echo -e "${RED}✗${NC} $1" >&2
}

usage() {
  cat <<EOF
Usage: opencode-init [OPTIONS] [target-dir]

Initialize OpenCode workflow in a project directory.

Options:
  --backend=TYPE    Workflow backend: beads (default) or jira-taskwarrior
  --stack=PRESET    Stack preset: backend (includes infra skills)
  --skills=LIST     Comma-separated skills to copy (e.g., postgres,kafka,docker)
  --lang=LANG       Language tooling: go, rust, or both
  --with-startup    Add flachnetz/startup library (runs go get if go.mod exists)
  --scaffold[=NAME] Scaffold a Go service from template (default name: service)
  --help, -h        Show this help message
  --list-skills     List all available skills

Arguments:
  target-dir        Directory to initialize (default: current directory)

Examples:
  opencode-init                                    # Init with Beads backend only
  opencode-init --stack=backend                    # Init with all backend infra skills
  opencode-init --stack=backend --lang=go          # Backend + Go tooling
  opencode-init --skills=postgres,docker           # Only specific skills
  opencode-init --lang=rust                        # Only Rust debugger + coding standards
  opencode-init --with-startup                     # Add startup library to existing go.mod
  opencode-init --scaffold=myapi                   # Scaffold Go service named 'myapi'
  opencode-init --scaffold --with-startup          # Scaffold with startup library

Backends:
  beads             Local file-based workflow (recommended for solo/small teams)
  jira-taskwarrior  Jira + Taskwarrior integration (for teams with Jira)

Stack Presets:
  backend           All backend infrastructure skills:
                    postgres, kafka, docker, kubernetes, helm, argocd,
                    migrations, observability, cicd, grpc

Language Tooling:
  go                Go coding standards + debugger agent
  rust              Rust coding standards + debugger agent
  both              Both Go and Rust tooling

Scaffolding:
  --scaffold        Creates a complete Go service from templates/go-service/
                    Uses flachnetz/startup for bootstrapping with:
                    - Postgres connection with migrations
                    - HTTP server with admin panel
                    - Prometheus metrics
                    - Graceful shutdown

EOF
  exit 0
}

list_skills() {
  echo "Available skills:"
  echo
  echo "Backend Infrastructure:"
  for skill in "${BACKEND_SKILLS[@]}"; do
    echo "  - $skill"
  done
  echo
  echo "Language-specific (included via --lang):"
  echo "  Go:   coding-standards, debugger-go agent"
  echo "  Rust: coding-standards, debugger-rust agent"
  echo
  echo "Other skills in repository:"
  for skill_path in "$OPENCODE_ROOT"/skills/*/SKILL.md; do
    skill_name=$(basename "$(dirname "$skill_path")")
    # Skip if already listed
    if [[ ! " ${BACKEND_SKILLS[*]} " =~ " ${skill_name} " ]] && \
       [[ "$skill_name" != "coding-standards" ]] && \
       [[ "$skill_name" != "workflow-backend" ]]; then
      echo "  - $skill_name"
    fi
  done
  exit 0
}

# Copy a skill directory
copy_skill() {
  local skill_name="$1"
  local skill_src="$OPENCODE_ROOT/skills/$skill_name"
  local skill_dst="$TARGET_DIR/skills/$skill_name"
  
  if [[ -d "$skill_src" ]]; then
    mkdir -p "$skill_dst"
    cp "$skill_src/SKILL.md" "$skill_dst/"
    log_success "Copied skill: $skill_name"
  else
    log_warn "Skill not found: $skill_name"
  fi
}

# Copy an agent file
copy_agent() {
  local agent_name="$1"
  local agent_src="$OPENCODE_ROOT/agent/$agent_name.md"
  local agent_dst="$TARGET_DIR/agent/$agent_name.md"
  
  if [[ -f "$agent_src" ]]; then
    cp "$agent_src" "$agent_dst"
    log_success "Copied agent: $agent_name"
  else
    log_warn "Agent not found: $agent_name"
  fi
}

# AIDEV-NOTE: scaffold_service copies templates/go-service/ to target,
# substituting {{.Module}} and {{.ServiceName}} placeholders.
scaffold_service() {
  local service_name="$1"
  local template_src="$OPENCODE_ROOT/templates/go-service"
  local service_dst="$TARGET_DIR"
  
  if [[ ! -d "$template_src" ]]; then
    log_error "Template not found: $template_src"
    return 1
  fi
  
  # Detect module path from existing go.mod or derive from directory
  local module_path
  if [[ -f "$service_dst/go.mod" ]]; then
    module_path=$(grep "^module " "$service_dst/go.mod" | awk '{print $2}')
    log_info "Using existing module: $module_path"
  else
    # Use directory name as module path base
    module_path="github.com/$(basename "$service_dst")"
    log_info "Using derived module path: $module_path"
  fi
  
  log_info "Scaffolding service '$service_name' from template..."
  
  # Create directory structure
  mkdir -p "$service_dst/cmd/server"
  mkdir -p "$service_dst/internal/handler"
  mkdir -p "$service_dst/internal/repository"
  mkdir -p "$service_dst/internal/service"
  mkdir -p "$service_dst/sql"
  
  # Process template files with variable substitution
  # Using sed for {{.Module}} and {{.ServiceName}} replacement
  local files_to_process=(
    "cmd/server/main.go"
    "internal/handler/handler.go"
    "internal/repository/repository.go"
    "internal/service/service.go"
  )
  
  for file in "${files_to_process[@]}"; do
    if [[ -f "$template_src/$file" ]]; then
      sed -e "s|{{\.Module}}|$module_path|g" \
          -e "s|{{\.ServiceName}}|$service_name|g" \
          "$template_src/$file" > "$service_dst/$file"
      log_success "Created: $file"
    fi
  done
  
  # Copy non-template files directly
  local files_to_copy=(
    "sql/001_initial.sql"
    "Dockerfile"
    "docker-compose.yml"
    "Makefile"
    ".gitignore"
  )
  
  for file in "${files_to_copy[@]}"; do
    if [[ -f "$template_src/$file" ]]; then
      # Ensure parent directory exists
      mkdir -p "$(dirname "$service_dst/$file")"
      cp "$template_src/$file" "$service_dst/$file"
      log_success "Copied: $file"
    fi
  done
  
  # Process go.mod.tmpl if no go.mod exists
  if [[ ! -f "$service_dst/go.mod" ]] && [[ -f "$template_src/go.mod.tmpl" ]]; then
    sed -e "s|{{\.Module}}|$module_path|g" \
        "$template_src/go.mod.tmpl" > "$service_dst/go.mod"
    log_success "Created: go.mod"
  fi
  
  # Copy README with substitution
  if [[ -f "$template_src/README.md" ]]; then
    sed -e "s|{{\.Module}}|$module_path|g" \
        -e "s|{{\.ServiceName}}|$service_name|g" \
        "$template_src/README.md" > "$service_dst/README.md"
    log_success "Created: README.md"
  fi
  
  log_success "Service scaffolded: $service_name"
}

# Add startup library to go.mod
add_startup_library() {
  if [[ ! -f "$TARGET_DIR/go.mod" ]]; then
    log_warn "No go.mod found. Skipping --with-startup (run 'go mod init' first or use --scaffold)"
    return 1
  fi
  
  log_info "Adding flachnetz/startup library..."
  
  (cd "$TARGET_DIR" && go get github.com/flachnetz/startup/v2@latest)
  
  if [[ $? -eq 0 ]]; then
    log_success "Added: github.com/flachnetz/startup/v2"
    
    # Also add common sub-packages
    (cd "$TARGET_DIR" && go get \
      github.com/flachnetz/startup/v2/startup_base@latest \
      github.com/flachnetz/startup/v2/startup_http@latest \
      github.com/flachnetz/startup/v2/startup_postgres@latest \
      2>/dev/null) || true
    
    log_success "Added startup sub-packages (base, http, postgres)"
  else
    log_error "Failed to add startup library"
    return 1
  fi
  
  # Copy the startup skill
  copy_skill "startup"
}

# ============================================
# Argument Parsing
# ============================================

while [[ $# -gt 0 ]]; do
  case "$1" in
    --backend=*)
      BACKEND="${1#*=}"
      shift
      ;;
    --backend)
      BACKEND="$2"
      shift 2
      ;;
    --stack=*)
      STACK="${1#*=}"
      shift
      ;;
    --stack)
      STACK="$2"
      shift 2
      ;;
    --skills=*)
      SKILLS="${1#*=}"
      shift
      ;;
    --skills)
      SKILLS="$2"
      shift 2
      ;;
    --lang=*)
      LANG="${1#*=}"
      shift
      ;;
    --lang)
      LANG="$2"
      shift 2
      ;;
    --with-startup)
      WITH_STARTUP="true"
      shift
      ;;
    --scaffold=*)
      SCAFFOLD="${1#*=}"
      shift
      ;;
    --scaffold)
      # Default service name if not specified
      SCAFFOLD="service"
      shift
      ;;
    --list-skills)
      list_skills
      ;;
    --help|-h)
      usage
      ;;
    -*)
      log_error "Unknown option: $1"
      echo "Run 'opencode-init --help' for usage."
      exit 1
      ;;
    *)
      TARGET_DIR="$1"
      shift
      ;;
  esac
done

# Validate backend
if [[ "$BACKEND" != "beads" && "$BACKEND" != "jira-taskwarrior" ]]; then
  log_error "Invalid backend: $BACKEND"
  echo "Valid backends: beads, jira-taskwarrior"
  exit 1
fi

# Validate stack
if [[ -n "$STACK" && "$STACK" != "backend" ]]; then
  log_error "Invalid stack: $STACK"
  echo "Valid stacks: backend"
  exit 1
fi

# Validate lang
if [[ -n "$LANG" && "$LANG" != "go" && "$LANG" != "rust" && "$LANG" != "both" ]]; then
  log_error "Invalid lang: $LANG"
  echo "Valid langs: go, rust, both"
  exit 1
fi

# ============================================
# Pre-flight Checks
# ============================================

log_info "Initializing OpenCode workflow with backend: ${BLUE}$BACKEND${NC}"
[[ -n "$STACK" ]] && log_info "Stack preset: ${BLUE}$STACK${NC}"
[[ -n "$LANG" ]] && log_info "Language tooling: ${BLUE}$LANG${NC}"
[[ -n "$SKILLS" ]] && log_info "Additional skills: ${BLUE}$SKILLS${NC}"
[[ -n "$SCAFFOLD" ]] && log_info "Scaffold service: ${BLUE}$SCAFFOLD${NC}"
[[ -n "$WITH_STARTUP" ]] && log_info "With startup library: ${BLUE}yes${NC}"

# Check target directory
if [[ ! -d "$TARGET_DIR" ]]; then
  log_info "Creating directory: $TARGET_DIR"
  mkdir -p "$TARGET_DIR"
fi

TARGET_DIR="$(cd "$TARGET_DIR" && pwd)"
log_info "Target directory: $TARGET_DIR"

# Check if already initialized
if [[ -f "$TARGET_DIR/opencode.json" ]]; then
  log_warn "opencode.json already exists in target directory"
  read -p "Overwrite? [y/N] " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    log_info "Aborted."
    exit 0
  fi
fi

# Check backend prerequisites
if [[ "$BACKEND" == "beads" ]]; then
  if ! command -v bd &> /dev/null; then
    log_warn "Beads CLI (bd) not found. Install with: brew install beads-ai/tap/beads"
  fi
elif [[ "$BACKEND" == "jira-taskwarrior" ]]; then
  if ! command -v task &> /dev/null; then
    log_warn "Taskwarrior (task) not found. Install with: brew install task"
  fi
  if ! command -v acli &> /dev/null; then
    log_warn "Atlassian CLI (acli) not found. See: https://developer.atlassian.com/cloud/acli/"
  fi
fi

# Check Go prerequisites for --with-startup and --scaffold
if [[ -n "$WITH_STARTUP" || -n "$SCAFFOLD" ]]; then
  if ! command -v go &> /dev/null; then
    log_error "Go is required for --with-startup and --scaffold options"
    log_info "Install Go from: https://go.dev/dl/"
    exit 1
  fi
fi

# ============================================
# Copy Files
# ============================================

log_info "Copying workflow files..."

# Create directory structure
mkdir -p "$TARGET_DIR/command"
mkdir -p "$TARGET_DIR/agent"
mkdir -p "$TARGET_DIR/skills/workflow-backend"
mkdir -p "$TARGET_DIR/backends/$BACKEND"
mkdir -p "$TARGET_DIR/lib"

# Copy commands
cp "$OPENCODE_ROOT/command/spec.md" "$TARGET_DIR/command/"
cp "$OPENCODE_ROOT/command/createtasks.md" "$TARGET_DIR/command/"
cp "$OPENCODE_ROOT/command/implement.md" "$TARGET_DIR/command/"
log_success "Copied commands: spec, createtasks, implement"

# Copy agents
cp "$OPENCODE_ROOT/agent/spec-mode.md" "$TARGET_DIR/agent/"
cp "$OPENCODE_ROOT/agent/create-tasks.md" "$TARGET_DIR/agent/"
log_success "Copied agents: spec-mode, create-tasks"

# Copy workflow skill
cp "$OPENCODE_ROOT/skills/workflow-backend/SKILL.md" "$TARGET_DIR/skills/workflow-backend/"
log_success "Copied skill: workflow-backend"

# Copy backend
cp "$OPENCODE_ROOT/backends/$BACKEND/index.js" "$TARGET_DIR/backends/$BACKEND/"
cp "$OPENCODE_ROOT/backends/$BACKEND/README.md" "$TARGET_DIR/backends/$BACKEND/"
log_success "Copied backend: $BACKEND"

# Copy backend loader
cp "$OPENCODE_ROOT/lib/backend-loader.js" "$TARGET_DIR/lib/"
log_success "Copied lib: backend-loader"

# Copy interface (for reference)
cp "$OPENCODE_ROOT/backends/interface.ts" "$TARGET_DIR/backends/"
log_success "Copied interface definition"

# ============================================
# Copy Stack Skills
# ============================================

if [[ "$STACK" == "backend" ]]; then
  log_info "Copying backend stack skills..."
  for skill in "${BACKEND_SKILLS[@]}"; do
    copy_skill "$skill"
  done
fi

# ============================================
# Copy Individual Skills
# ============================================

if [[ -n "$SKILLS" ]]; then
  log_info "Copying selected skills..."
  IFS=',' read -ra SKILL_ARRAY <<< "$SKILLS"
  for skill in "${SKILL_ARRAY[@]}"; do
    # Trim whitespace
    skill=$(echo "$skill" | xargs)
    copy_skill "$skill"
  done
fi

# ============================================
# Copy Language Tooling
# ============================================

if [[ "$LANG" == "go" || "$LANG" == "both" ]]; then
  log_info "Copying Go tooling..."
  for skill in "${GO_SKILLS[@]}"; do
    copy_skill "$skill"
  done
  for agent in "${GO_AGENTS[@]}"; do
    copy_agent "$agent"
  done
fi

if [[ "$LANG" == "rust" || "$LANG" == "both" ]]; then
  log_info "Copying Rust tooling..."
  for skill in "${RUST_SKILLS[@]}"; do
    copy_skill "$skill"
  done
  for agent in "${RUST_AGENTS[@]}"; do
    copy_agent "$agent"
  done
fi

# ============================================
# Scaffold Go Service
# ============================================

if [[ -n "$SCAFFOLD" ]]; then
  scaffold_service "$SCAFFOLD"
fi

# ============================================
# Add Startup Library
# ============================================

if [[ -n "$WITH_STARTUP" ]]; then
  add_startup_library
fi

# ============================================
# Generate opencode.json
# ============================================

log_info "Generating opencode.json..."

if [[ "$BACKEND" == "beads" ]]; then
  cat > "$TARGET_DIR/opencode.json" <<'EOF'
{
  "$schema": "https://opencode.ai/schemas/opencode.json",
  "workflow": {
    "backend": {
      "type": "beads",
      "config": {}
    }
  }
}
EOF
elif [[ "$BACKEND" == "jira-taskwarrior" ]]; then
  cat > "$TARGET_DIR/opencode.json" <<'EOF'
{
  "$schema": "https://opencode.ai/schemas/opencode.json",
  "workflow": {
    "backend": {
      "type": "jira-taskwarrior",
      "config": {
        "jiraSite": "YOUR_ORG.atlassian.net",
        "jiraProject": "YOUR_PROJECT_KEY",
        "jiraEmail": "your.email@example.com",
        "taskrcPath": "~/.taskrc",
        "taskDataLocation": "~/.task",
        "lmmNotesRoot": "./notes"
      }
    }
  }
}
EOF
  log_warn "Edit opencode.json to configure your Jira site and project"
fi

log_success "Generated opencode.json"

# ============================================
# Initialize Backend
# ============================================

if [[ "$BACKEND" == "beads" ]]; then
  if command -v bd &> /dev/null; then
    if [[ ! -d "$TARGET_DIR/.beads" ]]; then
      log_info "Initializing Beads workspace..."
      (cd "$TARGET_DIR" && bd init)
      log_success "Beads workspace initialized"
    else
      log_info "Beads workspace already exists"
    fi
  fi
fi

# ============================================
# Add to .gitignore
# ============================================

GITIGNORE="$TARGET_DIR/.gitignore"
if [[ -f "$GITIGNORE" ]]; then
  if ! grep -q "# OpenCode" "$GITIGNORE"; then
    log_info "Adding OpenCode entries to .gitignore..."
    cat >> "$GITIGNORE" <<'EOF'

# OpenCode
.beads/db/          # Beads database (local state)
notes/              # Spec notes (optional: remove if you want to track specs)
EOF
    log_success "Updated .gitignore"
  fi
else
  log_info "Creating .gitignore..."
  cat > "$GITIGNORE" <<'EOF'
# OpenCode
.beads/db/          # Beads database (local state)
notes/              # Spec notes (optional: remove if you want to track specs)
EOF
  log_success "Created .gitignore"
fi

# ============================================
# Summary
# ============================================

echo
echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}✓ OpenCode workflow initialized successfully!${NC}"
echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo
echo "Directory: $TARGET_DIR"
echo "Backend:   $BACKEND"
[[ -n "$STACK" ]] && echo "Stack:     $STACK"
[[ -n "$LANG" ]] && echo "Language:  $LANG"
[[ -n "$SCAFFOLD" ]] && echo "Scaffold:  $SCAFFOLD"
[[ -n "$WITH_STARTUP" ]] && echo "Startup:   enabled"
echo
echo "Files created:"
echo "  opencode.json              - Workflow configuration"
echo "  command/spec.md            - /spec command"
echo "  command/createtasks.md     - /createtasks command"
echo "  command/implement.md       - /implement command"
echo "  agent/spec-mode.md         - Spec writing agent"
echo "  agent/create-tasks.md      - Task creation agent"
echo "  backends/$BACKEND/         - Backend implementation"

if [[ "$STACK" == "backend" ]]; then
  echo
  echo "Backend stack skills:"
  for skill in "${BACKEND_SKILLS[@]}"; do
    echo "  skills/$skill/"
  done
fi

if [[ "$LANG" == "go" || "$LANG" == "both" ]]; then
  echo
  echo "Go tooling:"
  echo "  skills/coding-standards/   - Go coding standards"
  echo "  agent/debugger-go.md       - Go debugger agent"
fi

if [[ "$LANG" == "rust" || "$LANG" == "both" ]]; then
  echo
  echo "Rust tooling:"
  echo "  skills/coding-standards/   - Rust coding standards"
  echo "  agent/debugger-rust.md     - Rust debugger agent"
fi

if [[ -n "$SCAFFOLD" ]]; then
  echo
  echo "Scaffolded service '$SCAFFOLD':"
  echo "  cmd/server/main.go         - Entry point with startup bootstrap"
  echo "  internal/handler/          - HTTP handlers"
  echo "  internal/repository/       - Database access"
  echo "  internal/service/          - Business logic"
  echo "  sql/                       - Database migrations"
  echo "  Dockerfile                 - Multi-stage build"
  echo "  docker-compose.yml         - Local development"
  echo "  Makefile                   - Build targets"
fi

if [[ -n "$WITH_STARTUP" ]]; then
  echo
  echo "Startup library:"
  echo "  skills/startup/            - Startup library patterns"
  echo "  go.mod                     - Updated with startup deps"
fi

echo
echo -e "${BLUE}Next steps:${NC}"
if [[ -n "$SCAFFOLD" ]]; then
  echo "  1. Initialize deps:    go mod tidy"
  echo "  2. Start database:     docker-compose up -d postgres"
  echo "  3. Run service:        make run"
  echo "  4. View admin panel:   http://localhost:8080/admin"
  echo
  echo "Or use OpenCode workflow:"
elif [[ "$BACKEND" == "beads" ]]; then
  echo "  1. Start a feature:    /issue \"Your feature description\""
  echo "     (creates issue + starts spec in plan mode)"
  echo "  2. Create tasks:       /createtasks ISSUE-1"
  echo "  3. Start implementing: /implement ISSUE-1"
  echo "     (auto-switches to build mode)"
elif [[ "$BACKEND" == "jira-taskwarrior" ]]; then
  echo "  1. Edit opencode.json with your Jira site/project"
  echo "  2. Authenticate:       acli jira auth"
  echo "  3. Start a feature:    /issue \"Your feature description\""
  echo "     (creates Jira issue + starts spec in plan mode)"
  echo "  4. Create tasks:       /createtasks PROJ-123"
  echo "  5. Start implementing: /implement PROJ-123"
  echo "     (auto-switches to build mode)"
fi
echo
echo "Documentation: $OPENCODE_ROOT/backends/$BACKEND/README.md"
echo
