update_kafka_version() {
  log_info "Checking Kafka version..."
  
  if is_ignored "kafka"; then
    log_debug "Kafka is in ignore list, skipping"
    return 0
  fi
  
  local latest
  latest=$(fetch_kafka_version) || return 1
  log_debug "Latest Kafka version: $latest"
  
  local pinned
  pinned=$(get_pinned_version "kafka")
  if [[ -n "$pinned" ]]; then
    log_info "Kafka is pinned to version $pinned"
    latest="$pinned"
  fi
  
  # Find current Kafka versions (confluentinc/cp-kafka:X.X.X)
  local files
  files=$(find_version_files "cp-kafka:" | sort -u)
  
  if [[ -z "$files" ]]; then
    log_debug "No Kafka version references found"
    return 0
  fi
  
  # Detect current version
  local current
  current=$(echo "$files" | head -1 | xargs grep -oE 'cp-kafka:[0-9]+\.[0-9]+\.[0-9]+' | head -1 | sed 's/cp-kafka://')
  
  if [[ -z "$current" ]]; then
    log_warn "Could not detect current Kafka version"
    return 0
  fi
  
  log_debug "Current Kafka version: $current"
  
  if [[ "$current" == "$latest" ]]; then
    log_success "Kafka is already at latest version ($latest)"
    return 0
  fi
  
  # Major version bump warning
  if is_major_bump "$current" "$latest" && [[ -z "$FORCE" ]]; then
    echo
    log_warn "Kafka major version bump detected: $current → $latest"
    read -p "  Proceed with update? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
      log_info "Skipping Kafka update"
      return 0
    fi
  fi
  
  log_info "Updating Kafka: $current → $latest"
  
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    
    if grep -q "cp-kafka:$current" "$file"; then
      replace_version "$file" "cp-kafka:$current" "cp-kafka:$latest"
      log_change "Kafka" "$current" "$latest" "${file#$OPENCODE_ROOT/}"
    fi
  done <<< "$files"
}

update_github_actions() {
  log_info "Checking GitHub Actions versions..."
  
  if is_ignored "actions"; then
    log_debug "GitHub Actions is in ignore list, skipping"
    return 0
  fi
  
  local files
  files=$(find_version_files "uses: actions/" | sort -u)
  
  if [[ -z "$files" ]]; then
    log_debug "No GitHub Actions references found"
    return 0
  fi
  
  # AIDEV-NOTE: Process each action individually to avoid associative array issues
  local action_pairs="checkout:actions/checkout setup-go:actions/setup-go cache:actions/cache"
  
  for pair in $action_pairs; do
    local action_short="${pair%%:*}"
    local action_full="${pair##*:}"
    
    local latest
    latest=$(fetch_action_version "$action_full") || continue
    log_debug "Latest $action_full version: $latest"
    
    # Find current version in files
    local current
    current=$(grep -hoE "$action_short@v[0-9]+" $files 2>/dev/null | head -1 | grep -oE 'v[0-9]+') || true
    
    if [[ -z "$current" ]]; then
      log_debug "No $action_short references found"
      continue
    fi
    
    if [[ "$current" == "$latest" ]]; then
      log_success "$action_full is already at latest version ($latest)"
      continue
    fi
    
    log_info "Updating $action_full: $current → $latest"
    
    while IFS= read -r file; do
      [[ -z "$file" ]] && continue
      
      if grep -q "$action_full@$current" "$file"; then
        replace_version "$file" "$action_full@$current" "$action_full@$latest"
        log_change "$action_short" "$current" "$latest" "${file#$OPENCODE_ROOT/}"
      fi
    done <<< "$files"
  done
}

# ============================================
# Code Modernization Functions
# ============================================

# AIDEV-NOTE: modernize_go_code applies transformations from lib/go-modernizers.json
# to update code examples in skills/ to use new Go language features.
# This is conservative - only applies automatic transformations, logs manual review items.

modernize_go_code() {
  local modernizers_file="$OPENCODE_ROOT/lib/go-modernizers.json"
  
  if [[ ! -f "$modernizers_file" ]]; then
    log_error "Modernizers file not found: $modernizers_file"
    return 1
  fi
  
  log_info "Modernizing Go code examples..."
  
  # Get current Go version target
  local target_version
  target_version=$(grep -rhoE 'golang:1\.[0-9]+' "$OPENCODE_ROOT/skills" "$OPENCODE_ROOT/templates" 2>/dev/null | head -1 | sed 's/golang://')
  
  if [[ -z "$target_version" ]]; then
    log_warn "Could not detect target Go version"
    return 0
  fi
  
  log_debug "Target Go version: $target_version"
  
  # Extract major.minor as number for comparison
  local target_major="${target_version%%.*}"
  local target_minor="${target_version#*.}"
  
  # Find Go code blocks in markdown files
  local skill_files
  skill_files=$(find "$OPENCODE_ROOT/skills" -name "*.md" -type f)
  
  local transformations_applied=0
  local manual_review_items=()
  
  # Process each version's features up to target version
  local versions
  versions=$(jq -r '.versions | keys[]' "$modernizers_file" 2>/dev/null | sort -V)
  
  for version in $versions; do
    # Check if this version applies (version <= target)
    local v_major="${version%%.*}"
    local v_minor="${version#*.}"
    
    # Skip if version > target
    if [[ "$v_major" -gt "$target_major" ]] || 
       [[ "$v_major" -eq "$target_major" && "$v_minor" -gt "$target_minor" ]]; then
      continue
    fi
    
    log_debug "Applying modernizations for Go $version..."
    
    # Get features for this version
    local features
    features=$(jq -r ".versions.\"$version\".features | length" "$modernizers_file" 2>/dev/null)
    
    for ((i=0; i<features; i++)); do
      local name pattern_before pattern_after note
      name=$(jq -r ".versions.\"$version\".features[$i].name" "$modernizers_file")
      pattern_before=$(jq -r ".versions.\"$version\".features[$i].pattern.before // empty" "$modernizers_file")
      pattern_after=$(jq -r ".versions.\"$version\".features[$i].pattern.after // empty" "$modernizers_file")
      note=$(jq -r ".versions.\"$version\".features[$i].note // empty" "$modernizers_file")
      
      # If no pattern, it's a manual review item
      if [[ -z "$pattern_before" || -z "$pattern_after" ]]; then
        if [[ -n "$note" ]]; then
          manual_review_items+=("$name (Go $version): $note")
        fi
        continue
      fi
      
      # Apply transformation to each file
      while IFS= read -r file; do
        [[ -z "$file" ]] && continue
        
        # Check if pattern exists in file
        if grep -qE "$pattern_before" "$file" 2>/dev/null; then
          if [[ -n "$DRY_RUN" ]]; then
            echo -e "  ${YELLOW}[dry-run]${NC} Would apply '$name' modernization in ${file#$OPENCODE_ROOT/}"
          else
            # Apply the transformation
            if [[ "$(uname)" == "Darwin" ]]; then
              sed -i '' -E "s|$pattern_before|$pattern_after|g" "$file"
            else
              sed -i -E "s|$pattern_before|$pattern_after|g" "$file"
            fi
            echo -e "  ${GREEN}Applied${NC} '$name' modernization in ${file#$OPENCODE_ROOT/}"
          fi
          ((transformations_applied++))
          CHANGES+=("Modernize: $name in ${file#$OPENCODE_ROOT/}")
        fi
      done <<< "$skill_files"
    done
  done
  
  # Report results
  if [[ $transformations_applied -eq 0 ]]; then
    log_success "No automatic modernizations needed"
  else
    if [[ -n "$DRY_RUN" ]]; then
      log_info "Would apply $transformations_applied modernizations"
    else
      log_success "Applied $transformations_applied modernizations"
    fi
  fi
  
  # Report manual review items
  if [[ ${#manual_review_items[@]} -gt 0 ]]; then
    echo
    echo -e "${CYAN}Manual Review Suggestions:${NC}"
    for item in "${manual_review_items[@]}"; do
      echo "  - $item"
    done
  fi
}

# ============================================
# List Versions Command
# ============================================

list_versions() {
  echo
  echo -e "${BOLD}Current and Latest Versions${NC}"
  echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo
  
  printf "%-12s %-15s %-15s %s\n" "COMPONENT" "CURRENT" "LATEST" "STATUS"
  printf "%-12s %-15s %-15s %s\n" "---------" "-------" "------" "------"
  
  # Go
  local go_latest go_current
  go_latest=$(fetch_go_version 2>/dev/null) || go_latest="error"
  go_current=$(grep -rhoE 'golang:1\.[0-9]+' "$OPENCODE_ROOT/skills" "$OPENCODE_ROOT/templates" 2>/dev/null | head -1 | sed 's/golang://' || echo "none")
  local go_status
  if [[ "$go_current" == "$go_latest" ]]; then
    go_status="${GREEN}up-to-date${NC}"
  else
    go_status="${YELLOW}update available${NC}"
  fi
  printf "%-12s %-15s %-15s " "Go" "$go_current" "$go_latest"
  echo -e "$go_status"
  
  # Alpine
  local alpine_latest alpine_current
  alpine_latest=$(fetch_alpine_version 2>/dev/null) || alpine_latest="error"
  alpine_current=$(grep -rhoE 'alpine:3\.[0-9]+' "$OPENCODE_ROOT/skills" "$OPENCODE_ROOT/templates" 2>/dev/null | head -1 | sed 's/alpine://' || echo "none")
  local alpine_status
  if [[ "$alpine_current" == "$alpine_latest" ]]; then
    alpine_status="${GREEN}up-to-date${NC}"
  else
    alpine_status="${YELLOW}update available${NC}"
  fi
  printf "%-12s %-15s %-15s " "Alpine" "$alpine_current" "$alpine_latest"
  echo -e "$alpine_status"
  
  # Postgres (look for postgres:XX-alpine pattern to avoid port numbers)
  local pg_latest pg_current
  pg_latest=$(fetch_postgres_version 2>/dev/null) || pg_latest="error"
  pg_current=$(grep -rhoE 'postgres:[0-9]+-alpine' "$OPENCODE_ROOT/skills" "$OPENCODE_ROOT/templates" 2>/dev/null | head -1 | sed 's/postgres://' | sed 's/-alpine//' || echo "none")
  if [[ -z "$pg_current" || "$pg_current" == "none" ]]; then
    # Fallback: look for postgres:XX in image context (followed by -alpine or end of line)
    pg_current=$(grep -rhoE 'postgres:[0-9]+' "$OPENCODE_ROOT/skills" "$OPENCODE_ROOT/templates" 2>/dev/null | grep -v '5432' | head -1 | sed 's/postgres://' || echo "none")
  fi
  local pg_status
  if [[ "$pg_current" == "$pg_latest" ]]; then
    pg_status="${GREEN}up-to-date${NC}"
  else
    pg_status="${YELLOW}update available${NC}"
  fi
  printf "%-12s %-15s %-15s " "Postgres" "$pg_current" "$pg_latest"
  echo -e "$pg_status"
  
  # Redis (look for redis:X-alpine pattern to avoid port numbers)
  local redis_latest redis_current
  redis_latest=$(fetch_redis_version 2>/dev/null) || redis_latest="error"
  redis_current=$(grep -rhoE 'redis:[0-9]+-alpine' "$OPENCODE_ROOT/skills" "$OPENCODE_ROOT/templates" 2>/dev/null | head -1 | sed 's/redis://' | sed 's/-alpine//' || echo "none")
  if [[ -z "$redis_current" || "$redis_current" == "none" ]]; then
    # Fallback: look for redis:X in image context
    redis_current=$(grep -rhoE 'redis:[0-9]+' "$OPENCODE_ROOT/skills" "$OPENCODE_ROOT/templates" 2>/dev/null | grep -v '6379' | head -1 | sed 's/redis://' || echo "none")
  fi
  local redis_status
  if [[ "$redis_current" == "$redis_latest" ]]; then
    redis_status="${GREEN}up-to-date${NC}"
  else
    redis_status="${YELLOW}update available${NC}"
  fi
  printf "%-12s %-15s %-15s " "Redis" "$redis_current" "$redis_latest"
  echo -e "$redis_status"
  
  # Kafka
  local kafka_latest kafka_current
  kafka_latest=$(fetch_kafka_version 2>/dev/null) || kafka_latest="error"
  kafka_current=$(grep -rhoE 'cp-kafka:[0-9]+\.[0-9]+\.[0-9]+' "$OPENCODE_ROOT/skills" "$OPENCODE_ROOT/templates" 2>/dev/null | head -1 | sed 's/cp-kafka://' || echo "none")
  local kafka_status
  if [[ "$kafka_current" == "$kafka_latest" ]]; then
    kafka_status="${GREEN}up-to-date${NC}"
  else
    kafka_status="${YELLOW}update available${NC}"
  fi
  printf "%-12s %-15s %-15s " "Kafka" "$kafka_current" "$kafka_latest"
  echo -e "$kafka_status"
  
  echo
  
  # Show pinned versions if any
  if [[ -f "$VERSION_CONFIG" ]]; then
    local pinned
    pinned=$(jq -r '.pinned | to_entries[] | "\(.key): \(.value)"' "$VERSION_CONFIG" 2>/dev/null || true)
    if [[ -n "$pinned" ]]; then
      echo -e "${BOLD}Pinned Versions:${NC}"
      echo "$pinned" | while read -r line; do
        echo "  $line"
      done
      echo
    fi
    
    local ignored
    ignored=$(jq -r '.ignore[]? // empty' "$VERSION_CONFIG" 2>/dev/null || true)
    if [[ -n "$ignored" ]]; then
      echo -e "${BOLD}Ignored Components:${NC}"
      echo "$ignored" | while read -r line; do
        echo "  $line"
      done
      echo
    fi
  fi
  
  exit 0
}

# ============================================
# Argument Parsing
# ============================================

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      DRY_RUN="true"
      shift
      ;;
    --force)
      FORCE="true"
      shift
      ;;
    --component=*)
      COMPONENT="${1#*=}"
      shift
      ;;
    --component)
      COMPONENT="$2"
      shift 2
      ;;
    --modernize)
      MODERNIZE="true"
      shift
      ;;
    --verbose|-v)
      VERBOSE="true"
      shift
      ;;
    --list-versions)
      list_versions
      ;;
    --help|-h)
      usage
      ;;
    -*)
      log_error "Unknown option: $1"
      echo "Run 'opencode-update --help' for usage."
      exit 1
      ;;
    *)
      log_error "Unexpected argument: $1"
      echo "Run 'opencode-update --help' for usage."
      exit 1
      ;;
  esac
done

# Validate component
if [[ -n "$COMPONENT" ]]; then
  case "$COMPONENT" in
    go|alpine|postgres|redis|kafka|actions)
      ;;
    *)
      log_error "Invalid component: $COMPONENT"
      echo "Valid components: go, alpine, postgres, redis, kafka, actions"
      exit 1
      ;;
  esac
fi

# ============================================
# Pre-flight Checks
# ============================================

# Check for required tools
for cmd in curl jq; do
  if ! command -v "$cmd" &> /dev/null; then
    log_error "Required command not found: $cmd"
    exit 1
  fi
done

# Create temp directory
TEMP_DIR=$(mktemp -d)
log_debug "Using temp directory: $TEMP_DIR"

# Load version config
load_pinned_versions

# ============================================
# Main Update Logic
# ============================================

echo
echo -e "${BOLD}OpenCode Update${NC}"
echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo
[[ -n "$DRY_RUN" ]] && echo -e "${YELLOW}[DRY RUN MODE - No changes will be made]${NC}" && echo

# Run updates based on component filter
if [[ -z "$COMPONENT" ]] || [[ "$COMPONENT" == "go" ]]; then
  update_go_version
fi

if [[ -z "$COMPONENT" ]] || [[ "$COMPONENT" == "alpine" ]]; then
  update_alpine_version
fi

if [[ -z "$COMPONENT" ]] || [[ "$COMPONENT" == "postgres" ]]; then
  update_postgres_version
fi

if [[ -z "$COMPONENT" ]] || [[ "$COMPONENT" == "redis" ]]; then
  update_redis_version
fi

if [[ -z "$COMPONENT" ]] || [[ "$COMPONENT" == "kafka" ]]; then
  update_kafka_version
fi

if [[ -z "$COMPONENT" ]] || [[ "$COMPONENT" == "actions" ]]; then
  update_github_actions
fi

# Code modernization (if requested)
if [[ -n "$MODERNIZE" ]]; then
  modernize_go_code
fi

# ============================================
# Summary
# ============================================

echo
echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

if [[ ${#CHANGES[@]} -eq 0 ]]; then
  echo -e "${GREEN}✓ All components are up to date!${NC}"
else
  if [[ -n "$DRY_RUN" ]]; then
    echo -e "${YELLOW}Would make ${#CHANGES[@]} changes (dry run)${NC}"
  else
    echo -e "${GREEN}✓ Made ${#CHANGES[@]} updates${NC}"
  fi
  echo
  echo "Changes:"
  for change in "${CHANGES[@]}"; do
    echo "  - $change"
  done
fi

echo
